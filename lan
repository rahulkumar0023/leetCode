# 10. Service

```java
package com.yourcompany.lancelot.service;

import com.yourcompany.lancelot.dto.AppConfigResponse;
import com.yourcompany.lancelot.entity.AppConfigEntity;
import com.yourcompany.lancelot.repository.AppConfigRepository;
import java.util.Arrays;
import java.util.Collections;
import java.util.List;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

@Service
@RequiredArgsConstructor
public class AppConfigService {

    private final AppConfigRepository appConfigRepository;

    public AppConfigResponse getApp(String appId) {
        validateAppId(appId);

        AppConfigEntity entity = appConfigRepository.findByAppId(appId)
                .orElseThrow(() -> new IllegalArgumentException("App not found: " + appId));

        return mapToResponse(entity);
    }

    private AppConfigResponse mapToResponse(AppConfigEntity entity) {
        AppConfigResponse response = new AppConfigResponse();
        response.setAppId(entity.getAppId());
        response.setEnabled(entity.isEnabled());
        response.setClientId(entity.getClientId());
        response.setClientSecret(entity.getClientSecret());
        response.setIssuerUri(entity.getIssuerUri());
        response.setRedirectUri(entity.getRedirectUri());
        response.setScopes(parseScopes(entity.getScopes()));
        response.setPostLoginRedirectUrl(entity.getPostLoginRedirectUrl());
        response.setCookieName(entity.getCookieName());
        response.setSessionTtlSeconds(entity.getSessionTtlSeconds());
        return response;
    }

    private List<String> parseScopes(String scopes) {
        if (scopes == null || scopes.isBlank()) {
            return Collections.emptyList();
        }

        return Arrays.stream(scopes.split(","))
                .map(String::trim)
                .filter(value -> !value.isBlank())
                .toList();
    }

    private void validateAppId(String appId) {
        if (appId == null || appId.isBlank()) {
            throw new IllegalArgumentException("appId must not be blank");
        }
    }
}
```

