Yes. For `OidcTokenService`, without adding `mockwebserver`, use Mockito to mock the `WebClient` chain.

It is uglier, but works.

```java
@ExtendWith(MockitoExtension.class)
class OidcTokenServiceTest {

    @Mock private WebClient webClient;
    @Mock private WebClient.RequestBodyUriSpec requestBodyUriSpec;
    @Mock private WebClient.RequestBodySpec requestBodySpec;
    @Mock private WebClient.RequestHeadersSpec<?> requestHeadersSpec;
    @Mock private WebClient.ResponseSpec responseSpec;

    private OidcTokenService oidcTokenService;

    @BeforeEach
    void setUp() {
        oidcTokenService = new OidcTokenService(webClient);
    }

    @Test
    void exchangeToken_shouldReturnTokenResponse() {
        when(webClient.post()).thenReturn(requestBodyUriSpec);
        when(requestBodyUriSpec.uri("token-uri")).thenReturn(requestBodySpec);
        when(requestBodySpec.contentType(MediaType.APPLICATION_FORM_URLENCODED))
                .thenReturn(requestBodySpec);
        when(requestBodySpec.body(any(BodyInserter.class)))
                .thenReturn(requestHeadersSpec);
        when(requestHeadersSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.onStatus(any(), any())).thenReturn(responseSpec);
        when(responseSpec.bodyToMono(any(ParameterizedTypeReference.class)))
                .thenReturn(Mono.just(Map.of(
                        "access_token", "access-token",
                        "id_token", "id-token",
                        "refresh_token", "refresh-token"
                )));

        Map<String, Object> result = oidcTokenService.exchangeToken(
                "auth-code",
                "token-uri",
                validAppConfig(),
                authTransaction()
        );

        assertThat(result.get("access_token")).isEqualTo("access-token");
        assertThat(result.get("id_token")).isEqualTo("id-token");
        assertThat(result.get("refresh_token")).isEqualTo("refresh-token");

        verify(webClient).post();
        verify(requestBodyUriSpec).uri("token-uri");
        verify(requestBodySpec).contentType(MediaType.APPLICATION_FORM_URLENCODED);
    }

    @Test
    void exchangeToken_shouldThrowTechnicalException_whenWebClientFails() {
        when(webClient.post()).thenReturn(requestBodyUriSpec);
        when(requestBodyUriSpec.uri("token-uri")).thenReturn(requestBodySpec);
        when(requestBodySpec.contentType(MediaType.APPLICATION_FORM_URLENCODED))
                .thenReturn(requestBodySpec);
        when(requestBodySpec.body(any(BodyInserter.class)))
                .thenReturn(requestHeadersSpec);
        when(requestHeadersSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.onStatus(any(), any())).thenReturn(responseSpec);
        when(responseSpec.bodyToMono(any(ParameterizedTypeReference.class)))
                .thenReturn(Mono.error(new TechnicalException("Token exchange failed: invalid_grant")));

        assertThatThrownBy(() -> oidcTokenService.exchangeToken(
                "auth-code",
                "token-uri",
                validAppConfig(),
                authTransaction()
        ))
                .isInstanceOf(TechnicalException.class)
                .hasMessageContaining("Token exchange failed");
    }

    private AppConfigResponse validAppConfig() {
        AppConfigResponse appConfig = new AppConfigResponse();
        appConfig.setClientId("client-id");
        appConfig.setClientSecret("client-secret");
        return appConfig;
    }

    private AuthTransaction authTransaction() {
        AuthTransaction tx = new AuthTransaction();
        tx.setRedirectUri("http://localhost:8080/arthur-core/auth/callback");
        tx.setCodeVerifier("verifier-123");
        return tx;
    }
}
