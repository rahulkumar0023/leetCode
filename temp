## 3. Updated retry logic

This version removes `retrying/` entirely and uses `outgoing_e-invoicing/` for CFT.

```java
@Slf4j
@RequiredArgsConstructor
@Component
public class RetryFailedTransfersTasklet implements Tasklet {

    private final CosStorageService cosStorageService;
    private final CFTApiClient cftApiClient;

    @Value("${retry.failed-prefix:failed/}")
    private String failedPrefix;

    @Value("${retry.outgoing-prefix:outgoing_e-invoicing/}")
    private String outgoingPrefix;

    @Value("${retry.wait-seconds:30}")
    private long retryWaitSeconds;

    private static final String ZIP_PGP_SUFFIX = ".zip.pgp";
    private static final String ZIP_SUFFIX = ".zip";

    @Override
    public RepeatStatus execute(StepContribution contribution, ChunkContext chunkContext) {
        log.info("Starting retry of failed transfers");

        List<String> failedFiles = cosStorageService.listKeys(failedPrefix);

        for (String failedKey : failedFiles) {
            String fileName = Paths.get(failedKey).getFileName().toString();

            if (isValidRetryFile(fileName)) {
                processRetryFile(failedFiles, failedKey, fileName);
            }
        }

        log.info("Retry job finished");
        return RepeatStatus.FINISHED;
    }

    private void processRetryFile(List<String> failedFiles, String failedKey, String fileName) {
        String outgoingRetryKey = outgoingPrefix + fileName;

        try {
            log.info("Preparing retry for {}", fileName);

            cosStorageService.copyFile(failedKey, outgoingRetryKey);

            log.info("Retrying transfer for {} using {}", fileName, outgoingRetryKey);

            cftApiClient.notifyAndWaitForCompletion(
                    outgoingRetryKey,
                    fileName,
                    Duration.ofSeconds(retryWaitSeconds)
            );

            cleanupFilesWithSameBase(failedFiles, fileName);
            cosStorageService.deleteFile(outgoingRetryKey);

            log.info("Retry successful for {}", fileName);

        } catch (Exception ex) {
            log.warn("Retry failed for {}", fileName, ex);

            deleteOutgoingRetryCopyQuietly(outgoingRetryKey);
        }
    }

    private void deleteOutgoingRetryCopyQuietly(String outgoingRetryKey) {
        try {
            cosStorageService.deleteFile(outgoingRetryKey);
            log.info("Deleted temporary outgoing retry file {}", outgoingRetryKey);
        } catch (Exception ex) {
            log.warn("Failed to delete temporary outgoing retry file {}", outgoingRetryKey, ex);
        }
    }

    private boolean isValidRetryFile(String fileName) {
        String normalized = fileName.toLowerCase(Locale.ROOT);
        return normalized.endsWith(ZIP_PGP_SUFFIX)
                && (normalized.contains("finance") || normalized.contains("miles"));
    }

    private void cleanupFilesWithSameBase(List<String> allFiles, String referenceFileName) {
        String referenceBase = extractBaseName(referenceFileName);

        for (String key : allFiles) {
            String fileName = Paths.get(key).getFileName().toString();
            String candidateBase = extractBaseName(fileName);

            if (referenceBase.equals(candidateBase)) {
                try {
                    cosStorageService.deleteFile(key);
                    log.info("Deleted related failed file: {}", key);
                } catch (Exception e) {
                    log.warn("Failed to delete {}", key, e);
                }
            }
        }
    }

    String extractBaseName(String fileName) {
        if (fileName.endsWith(ZIP_PGP_SUFFIX)) {
            return fileName.substring(0, fileName.length() - ZIP_PGP_SUFFIX.length());
        }

        if (fileName.endsWith(ZIP_SUFFIX)) {
            return fileName.substring(0, fileName.length() - ZIP_SUFFIX.length());
        }

        int lastDot = fileName.lastIndexOf('.');
        if (lastDot > 0) {
            return fileName.substring(0, lastDot);
        }

        return fileName;
    }
}
```

