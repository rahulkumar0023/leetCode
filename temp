```java
private String extractPingResourceId(
        PartnersBEAP74737Get200ResponseResourcesInner pingResponse
) {
    if (pingResponse == null
            || pingResponse.getMeta() == null
            || pingResponse.getMeta().getLocation() == null
            || pingResponse.getMeta().getLocation().isBlank()) {
        throw new PingIntegrationException(
                "Ping returned no resource location"
        );
    }

    String location = pingResponse.getMeta().getLocation();

    int lastSlash = location.lastIndexOf('/');

    if (lastSlash < 0 || lastSlash == location.length() - 1) {
        throw new PingIntegrationException(
                "Ping returned an invalid resource location: " + location
        );
    }

    return location.substring(lastSlash + 1);
}
```

