package com.bnpp.pf.einvoice.connect.batch.tasklet;

import com.bnpp.pf.einvoice.connect.cos.service.CosStorageService;
import com.bnpp.pf.einvoice.connect.notifycft.CFTApiClient;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.batch.core.StepContribution;
import org.springframework.batch.core.scope.context.ChunkContext;
import org.springframework.batch.core.step.tasklet.Tasklet;
import org.springframework.batch.repeat.RepeatStatus;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

import java.nio.file.Paths;
import java.time.Duration;
import java.util.List;
import java.util.Locale;

@Slf4j
@RequiredArgsConstructor
@Component
public class RetryFailedTransfersTasklet implements Tasklet {

    private static final String ZIP_PGP_SUFFIX = ".zip.pgp";
    private static final String ZIP_SUFFIX = ".zip";

    private final CosStorageService cosStorageService;
    private final CFTApiClient cftApiClient;

    @Value("${retry.failed-prefix:failed/}")
    private String failedPrefix;

    @Value("${retry.outgoing-prefix:outgoing_e-invoice/}")
    private String outgoingPrefix;

    @Value("${retry.wait-seconds:30}")
    private long retryWaitSeconds;

    @Override
    public RepeatStatus execute(StepContribution contribution, ChunkContext chunkContext) {
        log.info("Starting retry of failed transfers");

        List<String> failedFiles = cosStorageService.listKeys(failedPrefix);

        if (failedFiles == null || failedFiles.isEmpty()) {
            log.info("No files found under {}", failedPrefix);
            return RepeatStatus.FINISHED;
        }

        for (String failedKey : failedFiles) {
            String fileName = Paths.get(failedKey).getFileName().toString();

            if (!isValidRetryFile(fileName)) {
                continue;
            }

            processRetryFile(failedKey, fileName);
        }

        log.info("Retry job finished");
        return RepeatStatus.FINISHED;
    }

    private void processRetryFile(String failedKey, String fileName) {
        String outgoingKey = outgoingPrefix + fileName;

        try {
            log.info("Preparing retry for {}", fileName);

            // 1) move from failed -> outgoing
            cosStorageService.moveFile(failedKey, outgoingKey);

            log.info("Retrying transfer for {} using {}", fileName, outgoingKey);

            cftApiClient.notifyAndWaitForCompletion(
                    outgoingKey,
                    fileName,
                    getRetryWaitDuration()
            );

            // 3) success -> delete only from outgoing
            cosStorageService.deleteFile(outgoingKey);

            log.info("Retry successful for {}. Deleted {}", fileName, outgoingKey);

        } catch (Exception ex) {
            log.warn("Retry failed for {}", outgoingKey, ex);

            // 4) failure -> move back from outgoing -> failed
            moveBackToFailedQuietly(outgoingKey, failedKey);
        }
    }

    private Duration getRetryWaitDuration() {
        return Duration.ofSeconds(retryWaitSeconds);
    }

    private boolean isValidRetryFile(String fileName) {
        String normalized = fileName.toLowerCase(Locale.ROOT);
        return normalized.endsWith(ZIP_PGP_SUFFIX)
                && (normalized.contains("finance")
                || normalized.contains("miles")
                || normalized.contains("generix"));
    }

    private void moveBackToFailedQuietly(String outgoingKey, String failedKey) {
        try {
            if (cosStorageService.fileExists(outgoingKey)) {
                cosStorageService.moveFile(outgoingKey, failedKey);
                log.info("Moved retry file back to failed location: {} -> {}", outgoingKey, failedKey);
            } else {
                log.warn("Outgoing retry file does not exist, cannot move back: {}", outgoingKey);
            }
        } catch (Exception moveEx) {
            log.error("Failed to move retry file back to failed location: {} -> {}", outgoingKey, failedKey, moveEx);
        }
    }

    String extractBaseName(String fileName) {
        if (fileName.endsWith(ZIP_PGP_SUFFIX)) {
            return fileName.substring(0, fileName.length() - ZIP_PGP_SUFFIX.length());
        }

        if (fileName.endsWith(ZIP_SUFFIX)) {
            return fileName.substring(0, fileName.length() - ZIP_SUFFIX.length());
        }

        int lastDot = fileName.lastIndexOf('.');
        if (lastDot > 0) {
            return fileName.substring(0, lastDot);
        }

        return fileName;
    }
}
```

### What changed

The important behavior changes are:

* `copyFile(...)` → `moveFile(...)`
* removed `cleanupFilesWithSameBase(...)`
* removed `deleteOutgoingCopyQuietly(...)`
* added `moveBackToFailedQuietly(...)`

### Why `cleanupFilesWithSameBase(...)` should be removed

That method is dangerous for this retry design because after one successful retry it deletes every file in `failed/` with the same base. If you have related files like Miles and Finance, or multiple variants, it can delete things you still want to retry later.

For your new rule, the retry batch should handle **each file independently**:

* one file enters retry
* that same file either succeeds and gets deleted
* or fails and goes back to failed

Nothing else should be touched.

### One small thing to check

I used `cosStorageService.fileExists(outgoingKey)` in the rollback helper. If your `CosStorageService` does not have that method, use this simpler version instead:

```java
