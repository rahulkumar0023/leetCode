    private void mockCallbackDependencies(Map<String, Object> tokenResponse) {
        when(redisAuthTransactionService.findByState("state-123")).thenReturn(authTransaction());
        when(partnerRepositoryClient.getApp("B2BOOST_BE")).thenReturn(validAppConfig());
        when(oidcDiscoveryClient.loadMetadata("https://ping.example.com")).thenReturn(metadata());
        when(oidcTokenService.exchangeToken(
                anyString(),
                anyString(),
                any(AppConfigResponse.class),
                any(AuthTransaction.class)
        )).thenReturn(tokenResponse);
    }

    private AppConfigResponse validAppConfig() {
        AppConfigResponse appConfig = new AppConfigResponse();
        appConfig.setAppId("B2BOOST_BE");
        appConfig.setEnabled(true);
        appConfig.setClientId("client-id");
        appConfig.setClientSecret("client-secret");
        appConfig.setIssuerUri("https://ping.example.com");
        appConfig.setRedirectUri("http://localhost:8080/arthur-core/auth/callback");
        appConfig.setScopes(List.of("openid", "profile", "email"));
        appConfig.setPostLoginRedirectUrl("http://localhost:8081/post-login");
        return appConfig;
    }

    private OidcMetadata metadata() {
        OidcMetadata metadata = new OidcMetadata();
        metadata.setAuthorizationEndpoint("https://ping.example.com/as/authorization.oauth2");
        metadata.setTokenEndpoint("https://ping.example.com/as/token.oauth2");
        return metadata;
    }

    private AuthTransaction authTransaction() {
        AuthTransaction tx = new AuthTransaction();
        tx.setState("state-123");
        tx.setNonce("nonce-123");
        tx.setCodeVerifier("verifier-123");
        tx.setAppId("B2BOOST_BE");
        tx.setRedirectUri("http://localhost:8080/arthur-core/auth/callback");
        tx.setPostLoginRedirectUrl("http://localhost:8081/post-login");
        return tx;
    }

    private Map<String, Object> validTokenResponse() {
        return Map.of(
                "access_token", "access-token",
                "id_token", "id-token",
                "refresh_token", "refresh-token"
        );
    }

    private UserResponse validUser() {
        SalesPointResponse salesPoint = new SalesPointResponse();
        salesPoint.setId("SP001");
        salesPoint.setLabel("Sales Point 1");
        salesPoint.setOrgUnitId("ORG001");

        UserResponse user = new UserResponse();
        user.setUserId("testuser");
        user.setUsername("testuser");
        user.setRoles(List.of("SELLER"));
        user.setSalesPoints(List.of(salesPoint));
        return user;
    }

    private UserSession validSession() {
        SalesPointResponse salesPoint = new SalesPointResponse();
        salesPoint.setId("SP001");
        salesPoint.setLabel("Sales Point 1");
        salesPoint.setOrgUnitId("ORG001");

        UserSession session = new UserSession();
        session.setSessionId("session-123");
        session.setAppId("B2BOOST_BE");
        session.setUserId("testuser");
        session.setUsername("testuser");
        session.setRoles(List.of("SELLER"));
        session.setSalesPoints(List.of(salesPoint));
        return session;
    }
