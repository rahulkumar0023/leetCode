# 10. Handoff service

```java
package com.bnpp.pf.arthur.core.service;

import com.bnpp.pf.arthur.core.dto.HandoffExchangeResponse;
import com.bnpp.pf.arthur.core.model.LoginHandoff;
import com.bnpp.pf.arthur.core.model.UserSession;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

import java.time.Instant;

@Service
@RequiredArgsConstructor
public class HandoffService {

    private final RedisLoginHandoffService redisLoginHandoffService;
    private final RedisSessionService redisSessionService;

    public HandoffExchangeResponse exchange(String code) {
        LoginHandoff handoff = redisLoginHandoffService.findByCode(code);

        if (handoff == null) {
            throw new IllegalStateException("Invalid or expired handoff code");
        }

        if (handoff.isUsed()) {
            throw new IllegalStateException("Handoff code already used");
        }

        if (handoff.getExpiresAt() != null && Instant.now().isAfter(handoff.getExpiresAt())) {
            redisLoginHandoffService.delete(code);
            throw new IllegalStateException("Handoff code expired");
        }

        UserSession session = redisSessionService.findBySessionId(handoff.getSessionId());
        if (session == null) {
            redisLoginHandoffService.delete(code);
            throw new IllegalStateException("Session not found for handoff code");
        }

        handoff.setUsed(true);
        redisLoginHandoffService.delete(code); // one-time use

        HandoffExchangeResponse response = new HandoffExchangeResponse();
        response.setUserId(session.getUserId());
        response.setUsername(session.getUsername());
        response.setEmail(session.getEmail());
        response.setRoles(session.getRoles());
        response.setAppId(session.getAppId());

        return response;
    }
}
```

