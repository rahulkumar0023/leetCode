package com.bnpp.pf.partner.repository.controller;

import com.bnpp.pf.partner.repository.dto.user.RelatedPartyResponse;
import com.bnpp.pf.partner.repository.dto.user.SalesPointResponse;
import com.bnpp.pf.partner.repository.dto.user.UserInfoResponse;
import com.bnpp.pf.partner.repository.dto.user.UserResponse;
import com.bnpp.pf.partner.repository.service.UserService;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import java.util.List;

import static org.mockito.Mockito.when;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(UserController.class)
class UserControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockitoBean
    private UserService userService;

    @Test
    void getUserById_shouldReturnUser() throws Exception {
        UserInfoResponse userInfo = new UserInfoResponse();
        userInfo.setFirstName("Test");
        userInfo.setLastName("User");
        userInfo.setEmails(List.of("test@test.com"));
        userInfo.setPhoneNumbers(List.of("+32123456789"));

        SalesPointResponse salesPoint =
                new SalesPointResponse("SP001", "Sales Point 1", "ORG001");

        UserResponse response = new UserResponse();
        response.setUserId("testuser");
        response.setUsername("testuser");
        response.setUserInfo(userInfo);
        response.setSalesPoints(List.of(salesPoint));
        response.setRelatedDealer(new RelatedPartyResponse("DLR001", "Dealer 1"));
        response.setRelatedZoneManager(new RelatedPartyResponse("ZM001", "Zone Manager 1"));
        response.setRoles(List.of("SELLER"));

        when(userService.getUserById("testuser")).thenReturn(response);

        mockMvc.perform(get("/users/testuser"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.userId").value("testuser"))
                .andExpect(jsonPath("$.username").value("testuser"))
                .andExpect(jsonPath("$.userInfo.firstName").value("Test"))
                .andExpect(jsonPath("$.userInfo.emails[0]").value("test@test.com"))
                .andExpect(jsonPath("$.salesPoints[0].id").value("SP001"))
                .andExpect(jsonPath("$.salesPoints[0].label").value("Sales Point 1"))
                .andExpect(jsonPath("$.salesPoints[0].orgUnitId").value("ORG001"))
                .andExpect(jsonPath("$.roles[0]").value("SELLER"));
    }
}
```

If your `SalesPointResponse` constructor has 4 fields including `relationshipType`, use:

