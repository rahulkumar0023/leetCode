package com.yourcompany.arthurcore.client;

import com.yourcompany.arthurcore.model.OidcMetadata;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Component;
import org.springframework.web.reactive.function.client.WebClient;

@Component
@RequiredArgsConstructor
public class OidcDiscoveryClient {

    private final WebClient webClient;

    public OidcMetadata loadMetadata(String issuerUri) {
        validateIssuerUri(issuerUri);

        return webClient.get()
                .uri(issuerUri + "/.well-known/openid-configuration")
                .retrieve()
                .bodyToMono(OidcMetadata.class)
                .block();
    }

    private void validateIssuerUri(String issuerUri) {
        if (issuerUri == null || issuerUri.isBlank()) {
            throw new IllegalArgumentException("issuerUri must not be blank");
        }
    }
}
