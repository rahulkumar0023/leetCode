private static final Pattern DATE_PATTERN =
        Pattern.compile("(\\d{4}-\\d{2}-\\d{2}|\\d{8,12})");

private Optional<LocalDate> extractDateFromFileName(String fileName) {
    Matcher matcher = DATE_PATTERN.matcher(fileName);

    if (!matcher.find()) {
        return Optional.empty();
    }

    String token = matcher.group();

    try {
        if (token.contains("-")) {
            return Optional.of(LocalDate.parse(token));
        }

        String datePart = token.substring(0, 8);
        return Optional.of(LocalDate.parse(datePart, DateTimeFormatter.BASIC_ISO_DATE));
    } catch (Exception e) {
        return Optional.empty();
    }
}
