Yes. Start with these **AuthService unit tests** first.

```java
@ExtendWith(MockitoExtension.class)
class AuthServiceTest {

    @Mock private LancelotClient lancelotClient;
    @Mock private OidcDiscoveryClient oidcDiscoveryClient;
    @Mock private RandomValueGenerator randomValueGenerator;
    @Mock private PkceService pkceService;
    @Mock private RedisAuthTransactionService redisAuthTransactionService;
    @Mock private RedisLoginHandoffService redisLoginHandoffService;
    @Mock private WebClient webClient;
    @Mock private JwtService jwtService;
    @Mock private RedisSessionService redisSessionService;

    @InjectMocks
    private AuthService authService;

    @Test
    void shouldThrowWhenAppIdBlank() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> authService.startAuthentication(" ")
        );

        assertEquals("APP_ID must not be blank", ex.getMessage());
        verifyNoInteractions(lancelotClient);
    }

    @Test
    void shouldThrowWhenAppConfigNotFound() {
        when(lancelotClient.getApp("B2BOOST_BE")).thenReturn(null);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> authService.startAuthentication("B2BOOST_BE")
        );

        assertEquals("App config not found", ex.getMessage());
    }

    @Test
    void shouldThrowWhenAppIsDisabled() {
        AppConfigResponse appConfig = validAppConfig();
        appConfig.setEnabled(false);

        when(lancelotClient.getApp("B2BOOST_BE")).thenReturn(appConfig);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> authService.startAuthentication("B2BOOST_BE")
        );

        assertEquals("App is disabled", ex.getMessage());
    }

    @Test
    void shouldStartAuthenticationSuccessfully() {
        AppConfigResponse appConfig = validAppConfig();
        OidcMetadata metadata = validMetadata();

        when(lancelotClient.getApp("B2BOOST_BE")).thenReturn(appConfig);
        when(oidcDiscoveryClient.loadMetadata("http://issuer")).thenReturn(metadata);

        when(randomValueGenerator.generate())
                .thenReturn("STATE123")
                .thenReturn("NONCE123")
                .thenReturn("VERIFIER123");

        when(pkceService.generateCodeChallenge("VERIFIER123"))
                .thenReturn("CHALLENGE123");

        String redirectUrl = authService.startAuthentication("B2BOOST_BE");

        assertTrue(redirectUrl.contains("http://keycloak/auth"));
        assertTrue(redirectUrl.contains("client_id=client-1"));
        assertTrue(redirectUrl.contains("response_type=code"));
        assertTrue(redirectUrl.contains("state=STATE123"));
        assertTrue(redirectUrl.contains("nonce=NONCE123"));
        assertTrue(redirectUrl.contains("code_challenge=CHALLENGE123"));
        assertTrue(redirectUrl.contains("code_challenge_method=S256"));

        ArgumentCaptor<AuthTransaction> captor =
                ArgumentCaptor.forClass(AuthTransaction.class);

        verify(redisAuthTransactionService).save(captor.capture());

        AuthTransaction tx = captor.getValue();

        assertEquals("STATE123", tx.getState());
        assertEquals("NONCE123", tx.getNonce());
        assertEquals("VERIFIER123", tx.getCodeVerifier());
        assertEquals("B2BOOST_BE", tx.getAppId());
        assertEquals("http://arthur/callback", tx.getRedirectUri());
        assertEquals("http://frontend/home", tx.getPostLoginRedirectUrl());
    }

    @Test
    void shouldThrowWhenCallbackStateInvalid() {
        when(redisAuthTransactionService.findByState("BAD_STATE"))
                .thenReturn(null);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> authService.handleCallback("CODE123", "BAD_STATE")
        );

        assertEquals("Invalid or expired state", ex.getMessage());
        verify(redisAuthTransactionService).findByState("BAD_STATE");
        verifyNoInteractions(redisSessionService);
    }

    private AppConfigResponse validAppConfig() {
        AppConfigResponse appConfig = new AppConfigResponse();
        appConfig.setAppId("B2BOOST_BE");
        appConfig.setEnabled(true);
        appConfig.setClientId("client-1");
        appConfig.setClientSecret("secret-1");
        appConfig.setIssuerUri("http://issuer");
        appConfig.setRedirectUri("http://arthur/callback");
        appConfig.setPostLoginRedirectUrl("http://frontend/home");
        appConfig.setScopes(List.of("openid", "profile", "email"));
        return appConfig;
    }

    private OidcMetadata validMetadata() {
        OidcMetadata metadata = new OidcMetadata();
        metadata.setAuthorizationEndpoint("http://keycloak/auth");
        metadata.setTokenEndpoint("http://keycloak/token");
        return metadata;
    }
}
