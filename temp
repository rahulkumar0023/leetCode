@ExtendWith(MockitoExtension.class)
class AuthControllerTest {

    @Mock
    private AuthService authService;

    @Mock
    private HandoffService handoffService;

    @Mock
    private LancelotClient lancelotClient;

    @Mock
    private HttpServletRequest request;

    @InjectMocks
    private AuthController authController;

    @Test
    void shouldStartAuthenticationUsingQueryAppId() {

        when(authService.startAuthentication("B2BOOST_NL"))
                .thenReturn("http://ping/login");

        ResponseEntity<Void> result =
                authController.startAuthentication(
                        null,
                        "B2BOOST_NL",
                        request
                );

        assertEquals(302, result.getStatusCode().value());
        verify(authService).startAuthentication("B2BOOST_NL");
    }
}
