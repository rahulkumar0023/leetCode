package com.yourcompany.batch.retry;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.batch.core.StepContribution;
import org.springframework.batch.core.scope.context.ChunkContext;
import org.springframework.batch.core.step.tasklet.Tasklet;
import org.springframework.batch.repeat.RepeatStatus;

import java.nio.file.Paths;
import java.time.Duration;
import java.util.List;
import java.util.stream.Collectors;

@Slf4j
@RequiredArgsConstructor
public class RetryFailedTransfersTasklet implements Tasklet {

    private final CosStorageService cosStorageService;
    private final CftApiClient cftApiClient;

    private static final String FAILED_PREFIX = "failed/";
    private static final String RETRYING_PREFIX = "retrying/";

    @Override
    public RepeatStatus execute(StepContribution contribution,
                                ChunkContext chunkContext) {

        log.info("Starting retry of failed transfers");

        List<String> failedFiles = cosStorageService.listFiles(FAILED_PREFIX);

        // ✅ Filter only relevant retry candidates
        List<String> retryCandidates = failedFiles.stream()
                .filter(key -> key.endsWith(".zip.pgp"))
                .filter(key -> {
                    String name = Paths.get(key).getFileName().toString().toLowerCase();
                    return name.contains("finance") || name.contains("miles");
                })
                .collect(Collectors.toList());

        for (String failedKey : retryCandidates) {

            String retryKey = failedKey.replaceFirst(FAILED_PREFIX, RETRYING_PREFIX);

            boolean claimed = cosStorageService.moveIfExists(failedKey, retryKey);

            if (!claimed) {
                continue;
            }

            try {

                String fileName = Paths.get(retryKey).getFileName().toString();

                log.info("Retrying transfer for {}", fileName);

                cftApiClient.notifyAndWaitForCompletion(
                        retryKey,
                        fileName,
                        Duration.ofSeconds(30)
                );

                // ✅ SUCCESS → cleanup all related files
                cleanupRelatedFailedFiles(failedFiles, failedKey);

                // delete retry file
                cosStorageService.deleteFile(retryKey);

                log.info("Retry successful for {}", fileName);

            } catch (Exception ex) {

                log.warn("Retry failed for {}", retryKey, ex);

                String failedAgain = retryKey.replaceFirst(RETRYING_PREFIX, FAILED_PREFIX);

                cosStorageService.moveFile(retryKey, failedAgain);
            }
        }

        log.info("Retry job finished");

        return RepeatStatus.FINISHED;
    }

    /**
     * Delete all files with same "date/base" in failed folder
     */
    private void cleanupRelatedFailedFiles(List<String> allFailedFiles, String originalFailedKey) {

        String originalName = Paths.get(originalFailedKey).getFileName().toString();

        // Example: finance_20240101.zip.pgp → finance_20240101
        String baseName = extractBaseName(originalName);

        List<String> relatedFiles = allFailedFiles.stream()
                .filter(key -> key.contains(baseName))
                .collect(Collectors.toList());

        for (String file : relatedFiles) {
            try {
                log.info("Deleting related failed file {}", file);
                cosStorageService.deleteFile(file);
            } catch (Exception e) {
                log.warn("Failed to delete {}", file, e);
            }
        }
    }

    /**
     * Extract base name without extensions
     * e.g. finance_20240101.zip.pgp → finance_20240101
     */
    private String extractBaseName(String fileName) {

        if (fileName.endsWith(".zip.pgp")) {
            return fileName.substring(0, fileName.length() - ".zip.pgp".length());
        }

        if (fileName.endsWith(".zip")) {
            return fileName.substring(0, fileName.length() - ".zip".length());
        }

        return fileName;
    }
}
```

