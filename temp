Yes — cover only `getApp`, `getUserById`, and validation.

```java
@ExtendWith(MockitoExtension.class)
class LancelotClientTest {

    @Mock
    private WebClient webClient;

    @Mock
    private WebClient.RequestHeadersUriSpec requestHeadersUriSpec;

    @Mock
    private WebClient.RequestHeadersSpec requestHeadersSpec;

    @Mock
    private WebClient.ResponseSpec responseSpec;

    @InjectMocks
    private LancelotClient lancelotClient;

    @BeforeEach
    void setup() {
        ReflectionTestUtils.setField(
                lancelotClient,
                "baseUrl",
                "http://lancelot"
        );
    }

    @Test
    void shouldGetAppSuccessfully() {
        AppConfigResponse appConfig = new AppConfigResponse();
        appConfig.setAppId("B2BOOST_BE");
        appConfig.setClientId("client-1");

        when(webClient.get()).thenReturn(requestHeadersUriSpec);
        when(requestHeadersUriSpec.uri(
                "http://lancelot/apps/{appId}",
                "B2BOOST_BE"
        )).thenReturn(requestHeadersSpec);
        when(requestHeadersSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.bodyToMono(AppConfigResponse.class))
                .thenReturn(Mono.just(appConfig));

        AppConfigResponse result =
                lancelotClient.getApp("B2BOOST_BE");

        assertEquals("B2BOOST_BE", result.getAppId());
        assertEquals("client-1", result.getClientId());
    }

    @Test
    void shouldGetUserByIdSuccessfully() {
        UserResponse user = new UserResponse();
        user.setUserId("testuser");
        user.setUsername("testuser");

        when(webClient.get()).thenReturn(requestHeadersUriSpec);
        when(requestHeadersUriSpec.uri(
                "http://lancelot/users/{userId}",
                "testuser"
        )).thenReturn(requestHeadersSpec);
        when(requestHeadersSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.bodyToMono(UserResponse.class))
                .thenReturn(Mono.just(user));

        UserResponse result =
                lancelotClient.getUserById("testuser");

        assertEquals("testuser", result.getUserId());
        assertEquals("testuser", result.getUsername());
    }

    @Test
    void shouldThrowWhenGetAppAppIdIsBlank() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> lancelotClient.getApp(" ")
        );

        assertEquals("appId must not be blank", ex.getMessage());
        verifyNoInteractions(webClient);
    }

    @Test
    void shouldThrowWhenGetAppAppIdIsNull() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> lancelotClient.getApp(null)
        );

        assertEquals("appId must not be blank", ex.getMessage());
        verifyNoInteractions(webClient);
    }
}
