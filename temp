# 🧩 Tasklet Implementation

Example:

```java
@Component
@RequiredArgsConstructor
public class RetryFailedTransfersTasklet implements Tasklet {

    private final CosStorageService cosStorageService;
    private final CftApiClient cftApiClient;

    @Value("${retry.failed.prefix:failed/}")
    private String failedPrefix;

    @Value("${retry.wait.time:30}")
    private int waitTime;

    @Override
    public RepeatStatus execute(StepContribution contribution,
                                ChunkContext chunkContext) throws Exception {

        List<String> failedFiles = cosStorageService.listFiles(failedPrefix);

        for (String key : failedFiles) {

            if (!key.endsWith(".zip.pgp")) {
                continue;
            }

            String fileName = key.substring(key.lastIndexOf('/') + 1);

            try {

                log.info("Retrying CFT trigger for {}", fileName);

                Duration wait = Duration.ofSeconds(waitTime);

                cftApiClient.notifyAndWaitForCompletion(key, fileName, wait);

                cosStorageService.deleteFile(key);

                log.info("Retry success. Deleted file from failed: {}", key);

            } catch (Exception ex) {

                log.warn("Retry failed for {}. Keeping file for next retry.", key);

            }
        }

        return RepeatStatus.FINISHED;
    }
}
```

