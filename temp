public PartnersBEAP74737PatchRequest toPatchRequest(UserEntity user) {
    Objects.requireNonNull(user, "User must not be null");

    PartnersBEAP74737PatchRequest request =
            new PartnersBEAP74737PatchRequest();

    request.setSchemas(List.of(
            "urn:ietf:params:scim:api:messages:2.0:PatchOp"
    ));

    List<PartnersBEAP74737PatchRequestOperationsInner> operations =
            new ArrayList<>();

    addReplaceOperation(operations, "givenName", user.getFirstName());
    addReplaceOperation(operations, "sn", user.getLastName());
    addReplaceOperation(operations, "cn", buildCommonName(user));
    addReplaceOperation(operations, "mail", user.getEmail());
    addReplaceOperation(operations, "mobile", user.getPhoneNumber());
    addReplaceOperation(operations, "status", mapStatus(user.getStatus()));

    request.setOperations(operations);

    return request;
}

private void addReplaceOperation(
        List<PartnersBEAP74737PatchRequestOperationsInner> operations,
        String path,
        Object value
) {
    if (value == null) {
        return;
    }

    PartnersBEAP74737PatchRequestOperationsInner operation =
            new PartnersBEAP74737PatchRequestOperationsInner();

    operation.setOp("replace");
    operation.setPath(path);
    operation.setValue(value);

    operations.add(operation);
}
```

