## 1. `As400UserSyncControllerTest`

A direct unit test is enough. Mock the service and verify that the controller returns the same response.

```java
package com.bnpp.pf.partner.repository.controller;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertSame;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import com.bnpp.pf.partner.repository.dto.as400.As400SyncResponse;
import com.bnpp.pf.partner.repository.dto.as400.As400UserSnapshotRequest;
import com.bnpp.pf.partner.repository.service.UserSynchronizationService;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.junit.jupiter.api.extension.ExtendWith;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;

@ExtendWith(MockitoExtension.class)
class As400UserSyncControllerTest {

    @Mock
    private UserSynchronizationService userSynchronizationService;

    private As400UserSyncController controller;

    @BeforeEach
    void setUp() {
        controller = new As400UserSyncController(
                userSynchronizationService
        );
    }

    @Test
    void shouldSynchronizeUserSuccessfully() {
        As400UserSnapshotRequest request =
                new As400UserSnapshotRequest();

        As400SyncResponse expectedResponse =
                As400SyncResponse.builder()
                        .status("ACCEPTED")
                        .message("User synchronized")
                        .build();

        when(userSynchronizationService.synchronize(request))
                .thenReturn(expectedResponse);

        ResponseEntity<As400SyncResponse> response =
                controller.synchronizeUser(request);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertSame(expectedResponse, response.getBody());

        verify(userSynchronizationService)
                .synchronize(request);
    }
}
```

If `As400UserSnapshotRequest` is a record or has no default constructor, instantiate it using its actual constructor or builder.

This should give essentially full coverage for the controller.

