# 4. Build Spring Security authentication

## `PostLoginService.java`

```java
package com.example.app.auth.service;

import com.example.app.auth.client.ArthurAuthClient;
import com.example.app.auth.dto.HandoffExchangeResponse;
import jakarta.servlet.http.HttpServletRequest;
import lombok.RequiredArgsConstructor;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.GrantedAuthority;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.security.core.context.SecurityContext;
import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.security.web.context.HttpSessionSecurityContextRepository;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
public class PostLoginService {

    private final ArthurAuthClient arthurAuthClient;

    public HandoffExchangeResponse loginWithHandoffCode(String code, HttpServletRequest request) {
        HandoffExchangeResponse response = arthurAuthClient.exchangeCode(code);

        List<GrantedAuthority> authorities = response.getRoles() == null
                ? List.of()
                : response.getRoles().stream()
                    .map(role -> role.startsWith("ROLE_")
                            ? new SimpleGrantedAuthority(role)
                            : new SimpleGrantedAuthority("ROLE_" + role))
                    .map(GrantedAuthority.class::cast)
                    .toList();

        AppUserPrincipal principal = new AppUserPrincipal(
                response.getUserId(),
                response.getUsername(),
                response.getEmail(),
                response.getAppId()
        );

        UsernamePasswordAuthenticationToken authentication =
                new UsernamePasswordAuthenticationToken(principal, null, authorities);

        SecurityContext context = SecurityContextHolder.createEmptyContext();
        context.setAuthentication(authentication);
        SecurityContextHolder.setContext(context);

        request.getSession(true).setAttribute(
                HttpSessionSecurityContextRepository.SPRING_SECURITY_CONTEXT_KEY,
                context
        );

        return response;
    }
}
```

