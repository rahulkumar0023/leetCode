This mapper converts your Partner Repository user into the generated SCIM model.

```java
package com.bnpp.pf.partner.repository.ping.mapper;

import java.util.Locale;
import java.util.Objects;
import java.util.stream.Collectors;
import java.util.stream.Stream;

import com.bnpp.pf.partner.repository.entity.UserEntity;
import com.bnpp.pf.partner.repository.ping.generated.model.PartnersBEAP74737;

import org.springframework.stereotype.Component;

@Component
public class PingUserMapper {

    public PartnersBEAP74737 toPingUser(UserEntity user) {
        Objects.requireNonNull(user, "User must not be null");

        PartnersBEAP74737 pingUser = new PartnersBEAP74737();

        pingUser.setGivenName(trimToNull(user.getFirstName()));
        pingUser.setSn(trimToNull(user.getLastName()));
        pingUser.setCn(buildCommonName(user));
        pingUser.setMail(trimToNull(user.getEmail()));
        pingUser.setMobile(trimToNull(user.getPhoneNumber()));
        pingUser.setStatus(mapStatus(user.getStatus()));

        return pingUser;
    }

    private String buildCommonName(UserEntity user) {
        return Stream.of(user.getFirstName(), user.getLastName())
                .map(this::trimToNull)
                .filter(Objects::nonNull)
                .collect(Collectors.joining(" "));
    }

    private String mapStatus(Object status) {
        if (status == null) {
            return null;
        }

        String normalizedStatus = status.toString()
                .trim()
                .toUpperCase(Locale.ROOT);

        return switch (normalizedStatus) {
            case "ACTIVE" -> "ACTIVE";
            case "INACTIVE", "DISABLED", "DELETED" -> "INACTIVE";
            default -> throw new IllegalArgumentException(
                    "Unsupported Ping user status: " + status
            );
        };
    }

    private String trimToNull(String value) {
        if (value == null || value.isBlank()) {
            return null;
        }

        return value.trim();
    }
}
