Here is a **final full JUnit class** aligned to your current `RetryFailedTransfersTasklet` behavior:

* `failed/ -> outgoing_e-invoice/`
* success -> `delete outgoing`
* failure -> `move outgoing back to failed`
* only valid `.zip.pgp` files with `finance|miles|generix`
* uses `fileExists(outgoingKey)` in rollback path

```java
package com.bnpp.pf.einvoice.connect.batch.tasklet;

import com.bnpp.pf.einvoice.connect.cos.service.CosStorageService;
import com.bnpp.pf.einvoice.connect.notifycft.CFTApiClient;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.batch.core.StepContribution;
import org.springframework.batch.core.scope.context.ChunkContext;
import org.springframework.batch.repeat.RepeatStatus;
import org.springframework.test.util.ReflectionTestUtils;

import java.time.Duration;
import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.Mockito.doThrow;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.verifyNoInteractions;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class RetryFailedTransfersTaskletTest {

    private static final Duration RETRY_WAIT = Duration.ofSeconds(30);

    @Mock
    private CosStorageService cosStorageService;

    @Mock
    private CFTApiClient cftApiClient;

    @Mock
    private StepContribution contribution;

    @Mock
    private ChunkContext chunkContext;

    @InjectMocks
    private RetryFailedTransfersTasklet tasklet;

    @BeforeEach
    void setUp() {
        ReflectionTestUtils.setField(tasklet, "failedPrefix", "failed/");
        ReflectionTestUtils.setField(tasklet, "outgoingPrefix", "outgoing_e-invoice/");
        ReflectionTestUtils.setField(tasklet, "retryWaitSeconds", 30L);
    }

    @Test
    void shouldRetryAndCleanupOnSuccess() {
        String failedKey = "failed/finance_invoices_202401011030.zip.pgp";
        String outgoingKey = "outgoing_e-invoice/finance_invoices_202401011030.zip.pgp";

        when(cosStorageService.listKeys("failed/"))
                .thenReturn(Collections.singletonList(failedKey));

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cosStorageService).moveFile(failedKey, outgoingKey);
        verify(cftApiClient).notifyAndWaitForCompletion(
                outgoingKey,
                "finance_invoices_202401011030.zip.pgp",
                RETRY_WAIT
        );
        verify(cosStorageService).deleteFile(outgoingKey);

        verify(cosStorageService, never()).deleteFile(failedKey);
        verify(cosStorageService, never()).fileExists(outgoingKey);
        verify(cosStorageService, never()).moveFile(outgoingKey, failedKey);
    }

    @Test
    void shouldMoveBackToFailedWhenCftFails() {
        String failedKey = "failed/miles_invoices_202401011030.zip.pgp";
        String outgoingKey = "outgoing_e-invoice/miles_invoices_202401011030.zip.pgp";

        when(cosStorageService.listKeys("failed/"))
                .thenReturn(Collections.singletonList(failedKey));
        when(cosStorageService.fileExists(outgoingKey))
                .thenReturn(true);

        doThrow(new RuntimeException("CFT failed"))
                .when(cftApiClient)
                .notifyAndWaitForCompletion(
                        outgoingKey,
                        "miles_invoices_202401011030.zip.pgp",
                        RETRY_WAIT
                );

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cosStorageService).moveFile(failedKey, outgoingKey);
        verify(cftApiClient).notifyAndWaitForCompletion(
                outgoingKey,
                "miles_invoices_202401011030.zip.pgp",
                RETRY_WAIT
        );
        verify(cosStorageService).fileExists(outgoingKey);
        verify(cosStorageService).moveFile(outgoingKey, failedKey);

        verify(cosStorageService, never()).deleteFile(outgoingKey);
        verify(cosStorageService, never()).deleteFile(failedKey);
    }

    @Test
    void shouldKeepFailedAsIsWhenCftFailsAndOutgoingDoesNotExist() {
        String failedKey = "failed/miles_invoices_202401011030.zip.pgp";
        String outgoingKey = "outgoing_e-invoice/miles_invoices_202401011030.zip.pgp";

        when(cosStorageService.listKeys("failed/"))
                .thenReturn(Collections.singletonList(failedKey));
        when(cosStorageService.fileExists(outgoingKey))
                .thenReturn(false);

        doThrow(new RuntimeException("CFT failed"))
                .when(cftApiClient)
                .notifyAndWaitForCompletion(
                        outgoingKey,
                        "miles_invoices_202401011030.zip.pgp",
                        RETRY_WAIT
                );

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cosStorageService).moveFile(failedKey, outgoingKey);
        verify(cftApiClient).notifyAndWaitForCompletion(
                outgoingKey,
                "miles_invoices_202401011030.zip.pgp",
                RETRY_WAIT
        );
        verify(cosStorageService).fileExists(outgoingKey);

        verify(cosStorageService, never()).moveFile(outgoingKey, failedKey);
        verify(cosStorageService, never()).deleteFile(outgoingKey);
        verify(cosStorageService, never()).deleteFile(failedKey);
    }

    @Test
    void shouldRetryGenerixFile() {
        String failedKey = "failed/generix_invoices_202401011030.zip.pgp";
        String outgoingKey = "outgoing_e-invoice/generix_invoices_202401011030.zip.pgp";

        when(cosStorageService.listKeys("failed/"))
                .thenReturn(Collections.singletonList(failedKey));

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cosStorageService).moveFile(failedKey, outgoingKey);
        verify(cftApiClient).notifyAndWaitForCompletion(
                outgoingKey,
                "generix_invoices_202401011030.zip.pgp",
                RETRY_WAIT
        );
        verify(cosStorageService).deleteFile(outgoingKey);

        verify(cosStorageService, never()).deleteFile(failedKey);
        verify(cosStorageService, never()).fileExists(outgoingKey);
        verify(cosStorageService, never()).moveFile(outgoingKey, failedKey);
    }

    @Test
    void shouldIgnoreNonZipPgpFiles() {
        List<String> failedFiles = Arrays.asList(
                "failed/finance_invoices_202401011030.zip",
                "failed/miles_invoices_202401011030.xml",
                "failed/miles_invoices_202401011030.pdf"
        );

        when(cosStorageService.listKeys("failed/"))
                .thenReturn(failedFiles);

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveFile(org.mockito.ArgumentMatchers.anyString(), org.mockito.ArgumentMatchers.anyString());
        verify(cosStorageService, never()).deleteFile(org.mockito.ArgumentMatchers.anyString());
        verify(cosStorageService, never()).fileExists(org.mockito.ArgumentMatchers.anyString());
    }

    @Test
    void shouldIgnoreZipPgpFilesWithoutExpectedNames() {
        List<String> failedFiles = Arrays.asList(
                "failed/random_file.zip.pgp",
                "failed/unknown_202401011030.zip.pgp"
        );

        when(cosStorageService.listKeys("failed/"))
                .thenReturn(failedFiles);

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveFile(org.mockito.ArgumentMatchers.anyString(), org.mockito.ArgumentMatchers.anyString());
        verify(cosStorageService, never()).deleteFile(org.mockito.ArgumentMatchers.anyString());
        verify(cosStorageService, never()).fileExists(org.mockito.ArgumentMatchers.anyString());
    }

    @Test
    void shouldReturnFinishedWhenNoFilesExist() {
        when(cosStorageService.listKeys("failed/"))
                .thenReturn(Collections.emptyList());

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveFile(org.mockito.ArgumentMatchers.anyString(), org.mockito.ArgumentMatchers.anyString());
        verify(cosStorageService, never()).deleteFile(org.mockito.ArgumentMatchers.anyString());
        verify(cosStorageService, never()).fileExists(org.mockito.ArgumentMatchers.anyString());
    }

    @Test
    void shouldExtractBaseNameForZipPgp() {
        String result = tasklet.extractBaseName("finance_invoices_202401011030.zip.pgp");
        assertThat(result).isEqualTo("finance_invoices_202401011030");
    }

    @Test
    void shouldExtractBaseNameForZip() {
        String result = tasklet.extractBaseName("finance_invoices_202401011030.zip");
        assertThat(result).isEqualTo("finance_invoices_202401011030");
    }

    @Test
    void shouldExtractBaseNameForPlainFile() {
        String result = tasklet.extractBaseName("finance_invoices_202401011030.xml");
        assertThat(result).isEqualTo("finance_invoices_202401011030");
    }

    @Test
    void shouldExtractBaseNameWithoutExtension() {
        String result = tasklet.extractBaseName("finance_invoices_202401011030");
        assertThat(result).isEqualTo("finance_invoices_202401011030");
    }
}
```

A few important notes from your failing screenshots:

* your failure tests **must stub**:

  ```java
  when(cosStorageService.fileExists(outgoingKey)).thenReturn(true);
  ```

  otherwise rollback never happens.
* the old test `shouldDeleteTemporaryOutgoingCopyAndKeepFailedFileOnCftFailure` is no longer valid with the new lifecycle, so this final class replaces that with:

  * `shouldMoveBackToFailedWhenCftFails`
  * `shouldKeepFailedAsIsWhenCftFailsAndOutgoingDoesNotExist`

The retry flow you described in your uploaded conversation history matches this updated behavior: move from `failed/` to `outgoing_e-invoice/`, then delete on success or move back on failure. 
