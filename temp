### 5. Success path

```java
@Test
void salesPoints_shouldReturnSalesPointsView() {

    UserSession session = new UserSession();

    SalesPoint sp = new SalesPoint();
    sp.setId("SP001");

    session.setSalesPoints(List.of(sp));

    when(redisSessionService.findBySessionId("session-123"))
            .thenReturn(session);

    ModelAndView mv =
            controller.salesPoints("B2BOOST_BE", "session-123");

    assertEquals("views/sales-points", mv.getViewName());

    assertEquals(
            session.getSalesPoints(),
            mv.getModel().get("salesPoints"));

    assertEquals(
            "B2BOOST_BE",
            mv.getModel().get("appId"));
}
```

