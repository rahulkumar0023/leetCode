void shouldCreateUserInPing() {
    UserEntity user = new UserEntity();
    user.setUserId("gps000001");

    PartnersBEAP74737Get200ResponseResourcesInner request =
            new PartnersBEAP74737Get200ResponseResourcesInner();

    PartnersBEAP74737Get200ResponseResourcesInner response =
            new PartnersBEAP74737Get200ResponseResourcesInner();

    when(pingUserMapper.toPingUser(user))
            .thenReturn(request);

    when(pingApi.partnersBEAP74737Post(request, null, null))
            .thenReturn(response);

    // Missing call
    pingUserClient.createUser(user);

    verify(pingUserMapper).toPingUser(user);
    verify(pingApi).partnersBEAP74737Post(request, null, null);
}
```

You can also assert the returned value when `createUser` returns the Ping response:

```java
var result = pingUserClient.createUser(user);

assertThat(result).isSameAs(response);
```

