## 1. RedisLoginHandoffServiceTest

```java
@ExtendWith(MockitoExtension.class)
class RedisLoginHandoffServiceTest {

    @Mock
    private RedisTemplate<String, Object> redisTemplate;

    @Mock
    private ValueOperations<String, Object> valueOperations;

    private final ObjectMapper objectMapper = new ObjectMapper();

    private RedisLoginHandoffService service;

    @BeforeEach
    void setUp() {
        ArthurSecurityProperties properties = new ArthurSecurityProperties();

        service = new RedisLoginHandoffService(
                redisTemplate,
                objectMapper,
                properties
        );
    }

    @Test
    void save_shouldStoreHandoffWithTtl() {
        LoginHandoff handoff = handoff();

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        service.save(handoff);

        verify(valueOperations).set(
                "handoff:code-123",
                handoff,
                Duration.ofSeconds(60)
        );
    }

    @Test
    void findByCode_shouldReturnNull_whenValueIsNull() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("handoff:code-123")).thenReturn(null);

        LoginHandoff result = service.findByCode("code-123");

        assertThat(result).isNull();
    }

    @Test
    void findByCode_shouldReturnHandoff_whenValueIsLoginHandoff() {
        LoginHandoff handoff = handoff();

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("handoff:code-123")).thenReturn(handoff);

        LoginHandoff result = service.findByCode("code-123");

        assertThat(result).isSameAs(handoff);
    }

    @Test
    void findByCode_shouldConvertMapToLoginHandoff() {
        Map<String, Object> value = Map.of(
                "code", "code-123",
                "sessionId", "session-123",
                "appId", "B2BOOST_BE",
                "redirectUrl", "http://localhost/post-login",
                "used", false
        );

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("handoff:code-123")).thenReturn(value);

        LoginHandoff result = service.findByCode("code-123");

        assertThat(result.getCode()).isEqualTo("code-123");
        assertThat(result.getSessionId()).isEqualTo("session-123");
        assertThat(result.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(result.getRedirectUrl()).isEqualTo("http://localhost/post-login");
        assertThat(result.isUsed()).isFalse();
    }

    @Test
    void delete_shouldDeleteHandoffCode() {
        service.delete("code-123");

        verify(redisTemplate).delete("handoff:code-123");
    }

    private LoginHandoff handoff() {
        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("code-123");
        handoff.setSessionId("session-123");
        handoff.setAppId("B2BOOST_BE");
        handoff.setRedirectUrl("http://localhost/post-login");
        handoff.setExpiresAt(Instant.now().plusSeconds(60));
        handoff.setUsed(false);
        return handoff;
    }
}
```

## 2. RedisSessionServiceTest

```java
@ExtendWith(MockitoExtension.class)
class RedisSessionServiceTest {

    @Mock
    private RedisTemplate<String, Object> redisTemplate;

    @Mock
    private ValueOperations<String, Object> valueOperations;

    private final ObjectMapper objectMapper = new ObjectMapper();

    private RedisSessionService service;

    @BeforeEach
    void setUp() {
        ArthurSecurityProperties properties = new ArthurSecurityProperties();

        service = new RedisSessionService(
                redisTemplate,
                properties,
                objectMapper
        );
    }

    @Test
    void save_shouldStoreSessionWithTtl() {
        UserSession session = session();

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        service.save(session);

        verify(valueOperations).set(
                "session:session-123",
                session,
                Duration.ofMinutes(60)
        );
    }

    @Test
    void findBySessionId_shouldReturnNull_whenValueIsNull() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("session:session-123")).thenReturn(null);

        UserSession result = service.findBySessionId("session-123");

        assertThat(result).isNull();
    }

    @Test
    void findBySessionId_shouldReturnSession_whenValueIsUserSession() {
        UserSession session = session();

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("session:session-123")).thenReturn(session);

        UserSession result = service.findBySessionId("session-123");

        assertThat(result).isSameAs(session);
    }

    @Test
    void findBySessionId_shouldConvertMapToUserSession() {
        Map<String, Object> value = Map.of(
                "sessionId", "session-123",
                "appId", "B2BOOST_BE",
                "userId", "testuser",
                "username", "testuser",
                "selectedSalesPointId", "SP001",
                "selectedOrgUnitId", "ORG001"
        );

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("session:session-123")).thenReturn(value);

        UserSession result = service.findBySessionId("session-123");

        assertThat(result.getSessionId()).isEqualTo("session-123");
        assertThat(result.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(result.getUserId()).isEqualTo("testuser");
        assertThat(result.getUsername()).isEqualTo("testuser");
        assertThat(result.getSelectedSalesPointId()).isEqualTo("SP001");
        assertThat(result.getSelectedOrgUnitId()).isEqualTo("ORG001");
    }

    @Test
    void delete_shouldDeleteSession() {
        service.delete("session-123");

        verify(redisTemplate).delete("session:session-123");
    }

    private UserSession session() {
        UserSession session = new UserSession();
        session.setSessionId("session-123");
        session.setAppId("B2BOOST_BE");
        session.setUserId("testuser");
        session.setUsername("testuser");
        session.setSelectedSalesPointId("SP001");
        session.setSelectedOrgUnitId("ORG001");
        return session;
    }
}
