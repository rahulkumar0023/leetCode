databaseChangeLog:

  # ---------------------------------------------------------------------------
  # 1. Remove existing duplicate relationship rows
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 007-01-remove-duplicate-relationships
      author: rahul.kumar
      dbms: postgresql

      changes:
        - sql:
            sql: |
              DELETE FROM person_sales_point_relationships
              WHERE ctid IN (
                  SELECT duplicate_ctid
                  FROM (
                      SELECT
                          ctid AS duplicate_ctid,
                          ROW_NUMBER() OVER (
                              PARTITION BY
                                  person_user_id,
                                  sales_point_id,
                                  relationship_type
                              ORDER BY ctid
                          ) AS row_number
                      FROM person_sales_point_relationships
                  ) duplicate_rows
                  WHERE row_number > 1
              );


  # ---------------------------------------------------------------------------
  # 2. Add relationship unique constraint
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 007-02-add-relationship-unique-constraint
      author: rahul.kumar

      preConditions:
        onFail: MARK_RAN
        onError: HALT
        not:
          uniqueConstraintExists:
            tableName: person_sales_point_relationships
            constraintName: uk_person_sales_point_relationship

      changes:
        - addUniqueConstraint:
            tableName: person_sales_point_relationships
            columnNames: person_user_id, sales_point_id, relationship_type
            constraintName: uk_person_sales_point_relationship


  # ---------------------------------------------------------------------------
  # 3. Create staging table
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 007-03-create-as400-user-import-staging
      author: rahul.kumar
      dbms: postgresql

      preConditions:
        onFail: MARK_RAN
        onError: HALT
        not:
          tableExists:
            tableName: as400_user_import_staging

      changes:
        - createTable:
            tableName: as400_user_import_staging
            columns:
              - column:
                  name: entity
                  type: varchar(100)

              - column:
                  name: source_record_type
                  type: varchar(50)

              - column:
                  name: related_parent
                  type: varchar(255)

              - column:
                  name: source_personal_id
                  type: varchar(255)

              - column:
                  name: gps_group_number
                  type: varchar(255)

              - column:
                  name: source_point_of_sales_id
                  type: varchar(255)

              - column:
