@ExtendWith(MockitoExtension.class)
class AuthServiceTest {

    @Mock
    private PartnerRepositoryClient partnerRepositoryClient;

    @Mock
    private OidcDiscoveryClient oidcDiscoveryClient;

    @Mock
    private RandomValueGenerator randomValueGenerator;

    @Mock
    private PkceService pkceService;

    @Mock
    private RedisAuthTransactionService redisAuthTransactionService;

    @Mock
    private RedisLoginHandoffService redisLoginHandoffService;

    @Mock
    private WebClient webClient;

    @Mock
    private JwtService jwtService;

    @Mock
    private RedisSessionService redisSessionService;

    @InjectMocks
    private AuthService authService;

    @Test
    void startAuthentication_shouldReturnAuthorizationUrl() {
        AppConfigResponse appConfig = new AppConfigResponse();
        appConfig.setAppId("B2BOOST_BE");
        appConfig.setEnabled(true);
        appConfig.setClientId("client-id");
        appConfig.setIssuerUri("https://ping.example.com");
        appConfig.setRedirectUri("http://localhost:8080/arthur-core/auth/callback");
        appConfig.setScopes(List.of("openid", "profile", "email"));
        appConfig.setPostLoginRedirectUrl("http://localhost:8081/post-login");

        OidcMetadata metadata = new OidcMetadata();
        metadata.setAuthorizationEndpoint("https://ping.example.com/as/authorization.oauth2");

        when(partnerRepositoryClient.getApp("B2BOOST_BE")).thenReturn(appConfig);
        when(oidcDiscoveryClient.loadMetadata("https://ping.example.com")).thenReturn(metadata);
        when(randomValueGenerator.generate())
                .thenReturn("state-123")
                .thenReturn("nonce-123")
                .thenReturn("verifier-123");
        when(pkceService.generateCodeChallenge("verifier-123")).thenReturn("challenge-123");

        String result = authService.startAuthentication("B2BOOST_BE");

        assertThat(result).contains("https://ping.example.com/as/authorization.oauth2");
        assertThat(result).contains("client_id=client-id");
        assertThat(result).contains("response_type=code");
        assertThat(result).contains("state=state-123");
        assertThat(result).contains("nonce=nonce-123");
        assertThat(result).contains("code_challenge=challenge-123");
        assertThat(result).contains("code_challenge_method=S256");

        verify(redisAuthTransactionService).save(any(AuthTransaction.class));
    }

    @Test
    void startAuthentication_shouldThrowException_whenAppIdBlank() {
        assertThatThrownBy(() -> authService.startAuthentication(" "))
                .isInstanceOf(IllegalArgumentException.class)
                .hasMessage("APP_ID must not be blank");

        verifyNoInteractions(partnerRepositoryClient);
    }

    @Test
    void startAuthentication_shouldThrowException_whenAppConfigIsNull() {
        when(partnerRepositoryClient.getApp("B2BOOST_BE")).thenReturn(null);

        assertThatThrownBy(() -> authService.startAuthentication("B2BOOST_BE"))
                .isInstanceOf(TechnicalException.class)
                .hasMessage("App config not found");
    }

    @Test
    void startAuthentication_shouldThrowException_whenAppIsDisabled() {
        AppConfigResponse appConfig = new AppConfigResponse();
        appConfig.setEnabled(false);

        when(partnerRepositoryClient.getApp("B2BOOST_BE")).thenReturn(appConfig);

        assertThatThrownBy(() -> authService.startAuthentication("B2BOOST_BE"))
                .isInstanceOf(TechnicalException.class)
                .hasMessage("App is disabled");
    }
}
