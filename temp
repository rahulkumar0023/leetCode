# ⚙️ 2. Tasklet (CORE LOGIC)

This is your main engine.

```java
@Component
@RequiredArgsConstructor
@Slf4j
public class RetryFailedFilesTasklet implements Tasklet {

    private final CosStorageService cosStorageService;
    private final ProcessingService processingService;

    private static final Pattern DATE_PATTERN = Pattern.compile("(\\d{8})");

    @Override
    public RepeatStatus execute(StepContribution contribution,
                                ChunkContext chunkContext) {

        List<String> failedFiles = cosStorageService.listFiles("failed/");

        for (String key : failedFiles) {

            String fileName = Paths.get(key).getFileName().toString().toLowerCase();

            if (!shouldRetry(fileName)) continue;

            try {
                log.info("Retrying file: {}", key);

                // 1. Move to processing
                String processingKey = key.replaceFirst("^failed/", "processing/");
                cosStorageService.moveFile(key, processingKey);

                // 2. Reprocess file
                processingService.process(processingKey);

                // 3. Cleanup same-date files AFTER success
                cleanupSameDateFiles(processingKey, failedFiles);

            } catch (Exception e) {
                log.warn("Retry failed for {}: {}", key, e.getMessage());
            }
        }

        return RepeatStatus.FINISHED;
    }

    private boolean shouldRetry(String name) {
        return name.endsWith(".zip.pgp") &&
               (name.contains("finance") || name.contains("miles"));
    }

    private void cleanupSameDateFiles(String successKey, List<String> failedFiles) {

        String successName = Paths.get(successKey).getFileName().toString();
        String date = extractDate(successName);

        if (date == null) return;

        failedFiles.stream()
                .filter(key -> key.contains(date))
                .forEach(key -> {
                    try {
                        cosStorageService.deleteFile(key);
                        log.info("Deleted failed file: {}", key);
                    } catch (Exception e) {
                        log.warn("Failed to delete {}: {}", key, e.getMessage());
                    }
                });
    }

    private String extractDate(String fileName) {
        Matcher m = DATE_PATTERN.matcher(fileName);
        return m.find() ? m.group(1) : null;
    }
}
```

