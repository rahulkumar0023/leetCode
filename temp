## Service

```java
package com.bnpp.pf.lancelot.service;

import com.bnpp.pf.lancelot.dto.*;
import com.bnpp.pf.lancelot.entity.UserEntity;
import com.bnpp.pf.lancelot.repository.UserRepository;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
public class UserService {

    private final UserRepository userRepository;

    public UserResponse getUserById(String userId) {
        UserEntity user = userRepository.findByUserId(userId)
                .orElseThrow(() -> new IllegalArgumentException("User not found: " + userId));

        return mapToResponse(user);
    }

    private UserResponse mapToResponse(UserEntity user) {
        UserResponse response = new UserResponse();
        response.setUserId(user.getUserId());
        response.setUsername(user.getUsername());

        UserInfoResponse userInfo = new UserInfoResponse();
        userInfo.setFirstName(user.getFirstName());
        userInfo.setLastName(user.getLastName());
        userInfo.setPhoneNumbers(
                user.getPhoneNumber() == null ? List.of() : List.of(user.getPhoneNumber())
        );
        userInfo.setEmails(
                user.getEmail() == null ? List.of() : List.of(user.getEmail())
        );
        response.setUserInfo(userInfo);

        response.setSalesPoints(List.of(
                new SalesPointResponse("SP001", "Sales Point 1")
        ));
        response.setRelatedDealer(new RelatedPartyResponse("DLR001", "Dealer 1"));
        response.setRelatedZoneManager(new RelatedPartyResponse("ZM001", "Zone Manager 1"));
        response.setBusinessLines(List.of("AUTO_LOANS"));
        response.setRoles(List.of("SELLER"));

        return response;
    }
}
```

