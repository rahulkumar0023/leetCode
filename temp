## Test coverage

```java
class RedisConfigTest {

    private final RedisConfig redisConfig = new RedisConfig();

    @Test
    void objectMapper_shouldSupportJavaTimeAndDisableTimestampSerialization() {
        ObjectMapper objectMapper = redisConfig.objectMapper();

        assertThat(objectMapper.isEnabled(
                SerializationFeature.WRITE_DATES_AS_TIMESTAMPS))
                .isFalse();
    }

    @Test
    void redisTemplate_shouldCreateTemplate() {
        RedisConnectionFactory connectionFactory =
                mock(RedisConnectionFactory.class);

        ObjectMapper objectMapper = redisConfig.objectMapper();

        RedisTemplate<String, Object> template =
                redisConfig.redisTemplate(connectionFactory, objectMapper);

        assertThat(template).isNotNull();
        assertThat(template.getConnectionFactory()).isSameAs(connectionFactory);
        assertThat(template.getKeySerializer())
                .isInstanceOf(StringRedisSerializer.class);
        assertThat(template.getHashKeySerializer())
                .isInstanceOf(StringRedisSerializer.class);
        assertThat(template.getValueSerializer())
                .isInstanceOf(Jackson2JsonRedisSerializer.class);
        assertThat(template.getHashValueSerializer())
                .isInstanceOf(Jackson2JsonRedisSerializer.class);
    }
}
