# Step 5: Lancelot client

Keep the previously configured URL.

```java
package com.yourcompany.arthurcore.client;

import com.yourcompany.arthurcore.model.AppConfigResponse;
import lombok.RequiredArgsConstructor;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;
import org.springframework.web.reactive.function.client.WebClient;

@Component
@RequiredArgsConstructor
public class LancelotClient {

    private final WebClient webClient;

    @Value("${lancelot.base-url}")
    private String baseUrl;

    public AppConfigResponse getApp(String appId) {
        validateAppId(appId);

        return webClient.get()
                .uri(baseUrl + "/apps/{appId}", appId)
                .retrieve()
                .bodyToMono(AppConfigResponse.class)
                .block();
    }

    private void validateAppId(String appId) {
        if (appId == null || appId.isBlank()) {
            throw new IllegalArgumentException("appId must not be blank");
        }
    }
}
```

