            file: ../data/as400-users.csv
            relativeToChangelogFile: true
            tableName: as400_user_import_staging
            encoding: UTF-8
            separator: ","
            quotchar: '"'
            usePreparedStatements: true

            columns:
              - column:
                  header: entity
                  name: entity
