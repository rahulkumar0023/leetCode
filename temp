# Step 10: Auth service for `/auth/start`

This is the first functionality we implement now.

```java
package com.yourcompany.arthurcore.service;

import com.yourcompany.arthurcore.client.LancelotClient;
import com.yourcompany.arthurcore.client.OidcDiscoveryClient;
import com.yourcompany.arthurcore.model.AppConfigResponse;
import com.yourcompany.arthurcore.model.AuthTransaction;
import com.yourcompany.arthurcore.model.OidcMetadata;
import com.yourcompany.arthurcore.util.RandomValueGenerator;
import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;
import java.time.Instant;
import java.util.List;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

@Service
@RequiredArgsConstructor
public class AuthService {

    private final LancelotClient lancelotClient;
    private final OidcDiscoveryClient oidcDiscoveryClient;
    private final RandomValueGenerator randomValueGenerator;
    private final PkceService pkceService;
    private final RedisAuthTransactionService redisAuthTransactionService;

    public String startAuthentication(String appId) {
        validateAppId(appId);

        AppConfigResponse appConfig = lancelotClient.getApp(appId);
        validateAppConfig(appConfig);

        OidcMetadata metadata = oidcDiscoveryClient.loadMetadata(appConfig.getIssuerUri());

        String state = randomValueGenerator.generate();
        String nonce = randomValueGenerator.generate();
        String codeVerifier = randomValueGenerator.generate();
        String codeChallenge = pkceService.generateCodeChallenge(codeVerifier);

        AuthTransaction transaction = new AuthTransaction();
        transaction.setState(state);
        transaction.setNonce(nonce);
        transaction.setCodeVerifier(codeVerifier);
        transaction.setAppId(appConfig.getAppId());
        transaction.setRedirectUri(appConfig.getRedirectUri());
        transaction.setPostLoginRedirectUrl(appConfig.getPostLoginRedirectUrl());
        transaction.setCreatedAt(Instant.now());

        redisAuthTransactionService.save(transaction);

        return buildAuthorizeUrl(metadata, appConfig, state, nonce, codeChallenge);
    }

    private String buildAuthorizeUrl(
            OidcMetadata metadata,
            AppConfigResponse appConfig,
            String state,
            String nonce,
            String codeChallenge) {

        List<String> scopes = appConfig.getScopes();
        String scopeValue = scopes == null || scopes.isEmpty()
                ? "openid"
                : String.join(" ", scopes);

        return metadata.getAuthorizationEndpoint()
                + "?client_id=" + encode(appConfig.getClientId())
                + "&response_type=code"
                + "&scope=" + encode(scopeValue)
                + "&redirect_uri=" + encode(appConfig.getRedirectUri())
                + "&state=" + encode(state)
                + "&nonce=" + encode(nonce)
                + "&code_challenge=" + encode(codeChallenge)
                + "&code_challenge_method=S256";
    }

    private String encode(String value) {
        return URLEncoder.encode(value, StandardCharsets.UTF_8);
    }

    private void validateAppId(String appId) {
        if (appId == null || appId.isBlank()) {
            throw new IllegalArgumentException("APP_ID must not be blank");
        }
    }

    private void validateAppConfig(AppConfigResponse appConfig) {
        if (appConfig == null) {
            throw new IllegalStateException("App config not found");
        }
        if (!appConfig.isEnabled()) {
            throw new IllegalStateException("App is disabled");
        }
        if (appConfig.getClientId() == null || appConfig.getClientId().isBlank()) {
            throw new IllegalStateException("Missing clientId");
        }
        if (appConfig.getIssuerUri() == null || appConfig.getIssuerUri().isBlank()) {
            throw new IllegalStateException("Missing issuerUri");
        }
        if (appConfig.getRedirectUri() == null || appConfig.getRedirectUri().isBlank()) {
            throw new IllegalStateException("Missing redirectUri");
        }
    }
}
```

