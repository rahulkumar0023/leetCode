  - changeSet:
      id: 007-05-upsert-users
      author: rahul.kumar
      dbms: postgresql

      changes:
        - sql:
            sql: |
              INSERT INTO users (
                  user_id,
                  username,
                  gps_group_number,
                  source_personal_id,
                  entity,
                  first_name,
                  last_name,
                  email,
                  phone_number,
                  language,
                  status
              )
              SELECT DISTINCT ON (BTRIM(gps_group_number))
                  BTRIM(gps_group_number),
                  BTRIM(gps_group_number),
                  BTRIM(gps_group_number),
                  BTRIM(source_personal_id),
                  BTRIM(entity),
                  BTRIM(first_name),
                  BTRIM(surname),
                  NULLIF(BTRIM(email), ''),
                  NULLIF(BTRIM(phone_number), ''),
                  NULLIF(BTRIM(language), ''),
                  BTRIM(user_status)
              FROM as400_user_import_staging
              WHERE gps_group_number IS NOT NULL
                AND BTRIM(gps_group_number) <> ''
              ORDER BY
                  BTRIM(gps_group_number),
                  imported_at DESC

              ON CONFLICT (user_id)
              DO UPDATE SET
                  username = EXCLUDED.username,
                  gps_group_number = EXCLUDED.gps_group_number,
                  source_personal_id = EXCLUDED.source_personal_id,
                  entity = EXCLUDED.entity,
                  first_name = EXCLUDED.first_name,
                  last_name = EXCLUDED.last_name,
                  email = EXCLUDED.email,
                  phone_number = EXCLUDED.phone_number,
                  language = EXCLUDED.language,
                  status = EXCLUDED.status;


  # ---------------------------------------------------------------------------
  # 6. Upsert sales points
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 007-06-upsert-sales-points
      author: rahul.kumar
      dbms: postgresql

      changes:
        - sql:
            sql: |
