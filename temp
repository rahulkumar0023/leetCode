For `AuthController`, add `@WebMvcTest` coverage for these 4 flows:

```text
/auth/start with APP_ID header
/auth/start with appId query param
/auth/start duplicate request reuse
/auth/callback sets cookie + redirects
/auth/handoff/exchange returns response
```

Use this as the base:

```java
@WebMvcTest(AuthController.class)
class AuthControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockitoBean
    private AuthService authService;

    @MockitoBean
    private HandoffService handoffService;

    @MockitoBean
    private PartnerRepositoryClient partnerRepositoryClient;

    @Test
    void startAuthentication_shouldRedirect_whenAppIdHeaderPresent() throws Exception {
        when(authService.startAuthentication("B2BOOST_BE"))
                .thenReturn("https://ping.example.com/auth");

        mockMvc.perform(get("/auth/start")
                        .header("APP_ID", "B2BOOST_BE"))
                .andExpect(status().isFound())
                .andExpect(header().string("Location", "https://ping.example.com/auth"));
    }

    @Test
    void startAuthentication_shouldRedirect_whenAppIdQueryParamPresent() throws Exception {
        when(authService.startAuthentication("B2BOOST_BE"))
                .thenReturn("https://ping.example.com/auth");

        mockMvc.perform(get("/auth/start")
                        .param("appId", "B2BOOST_BE"))
                .andExpect(status().isFound())
                .andExpect(header().string("Location", "https://ping.example.com/auth"));
    }

    @Test
    void startAuthentication_shouldThrowBadRequest_whenAppIdMissing() throws Exception {
        mockMvc.perform(get("/auth/start"))
                .andExpect(status().isBadRequest());
    }

    @Test
    void startAuthentication_shouldReusePendingRedirect_whenDuplicateWithinTenSeconds() throws Exception {
        MockHttpSession session = new MockHttpSession();
        session.setAttribute("AUTH_PENDING_REDIRECT", "https://ping.example.com/auth");
        session.setAttribute("AUTH_PENDING_TIME", System.currentTimeMillis());

        mockMvc.perform(get("/auth/start")
                        .session(session)
                        .header("APP_ID", "B2BOOST_BE"))
                .andExpect(status().isFound())
                .andExpect(header().string("Location", "https://ping.example.com/auth"));

        verifyNoInteractions(authService);
    }

    @Test
    void callback_shouldSetCookieAndRedirectToSalesPoints() throws Exception {
        AuthResult authResult = new AuthResult("session-123", "B2BOOST_BE");

        when(authService.handleCallback("auth-code", "state-123"))
                .thenReturn(authResult);

        mockMvc.perform(get("/auth/callback")
                        .param("code", "auth-code")
                        .param("state", "state-123"))
                .andExpect(status().isFound())
                .andExpect(header().string(
                        "Location",
                        "/arthur-core/sales-points?appId=B2BOOST_BE"
                ))
                .andExpect(cookie().value("ARTHUR_SESSION", "session-123"))
                .andExpect(cookie().httpOnly("ARTHUR_SESSION", true))
                .andExpect(cookie().secure("ARTHUR_SESSION", true))
                .andExpect(cookie().path("ARTHUR_SESSION", "/"))
                .andExpect(cookie().maxAge("ARTHUR_SESSION", 3600));
    }

    @Test
    void exchange_shouldReturnHandoffExchangeResponse() throws Exception {
        HandoffExchangeResponse response = new HandoffExchangeResponse();
        response.setUserId("testuser");
        response.setUsername("testuser");
        response.setEmail("test@test.com");
        response.setRoles(List.of("SELLER"));
        response.setAppId("B2BOOST_BE");
        response.setSelectedSalesPointId("SP001");
        response.setSelectedOrgUnitId("ORG001");

        when(handoffService.exchange("code-123")).thenReturn(response);

        mockMvc.perform(post("/auth/handoff/exchange")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content("""
                                {
                                  "code": "code-123"
                                }
                                """))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.userId").value("testuser"))
                .andExpect(jsonPath("$.username").value("testuser"))
                .andExpect(jsonPath("$.email").value("test@test.com"))
                .andExpect(jsonPath("$.roles[0]").value("SELLER"))
                .andExpect(jsonPath("$.appId").value("B2BOOST_BE"))
                .andExpect(jsonPath("$.selectedSalesPointId").value("SP001"))
                .andExpect(jsonPath("$.selectedOrgUnitId").value("ORG001"));
    }
}
```

