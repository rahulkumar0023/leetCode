```

---

## Example

```java
@WebMvcTest(AuthController.class)
class AuthControllerTest {

    @Autowired
    MockMvc mvc;

    @MockBean
    AuthService authService;

    @Test
    void shouldRedirectStart() throws Exception {

        when(authService.startAuthentication("B2BOOST_BE"))
                .thenReturn("http://keycloak");

        mvc.perform(get("/auth/start")
                .param("appId", "B2BOOST_BE"))
           .andExpect(status().isFound());
    }
}
```

