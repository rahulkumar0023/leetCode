@ExtendWith(MockitoExtension.class)
class RedisLoginHandoffServiceTest {

    @Mock
    private RedisTemplate<String, Object> redisTemplate;

    @Mock
    private ValueOperations<String, Object> valueOperations;

    @InjectMocks
    private RedisLoginHandoffService redisLoginHandoffService;

    @Test
    void shouldSaveLoginHandoff() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("CODE123");

        redisLoginHandoffService.save(handoff);

        verify(valueOperations).set(
                eq("handoff:CODE123"),
                eq(handoff),
                eq(Duration.ofMinutes(1))
        );
    }

    @Test
    void shouldFindByCodeWhenStoredAsObject() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("CODE123");
        handoff.setSessionId("SESSION123");

        when(valueOperations.get("handoff:CODE123"))
                .thenReturn(handoff);

        LoginHandoff result =
                redisLoginHandoffService.findByCode("CODE123");

        assertNotNull(result);
        assertEquals("CODE123", result.getCode());
        assertEquals("SESSION123", result.getSessionId());
    }

    @Test
    void shouldReturnNullWhenCodeMissing() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        when(valueOperations.get("handoff:MISSING"))
                .thenReturn(null);

        LoginHandoff result =
                redisLoginHandoffService.findByCode("MISSING");

        assertNull(result);
    }

    @Test
    void shouldConvertMapToLoginHandoff() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        Map<String, Object> map = new HashMap<>();
        map.put("code", "CODE123");
        map.put("sessionId", "SESSION123");
        map.put("used", false);

        when(valueOperations.get("handoff:CODE123"))
                .thenReturn(map);

        LoginHandoff result =
                redisLoginHandoffService.findByCode("CODE123");

        assertNotNull(result);
        assertEquals("CODE123", result.getCode());
        assertEquals("SESSION123", result.getSessionId());
        assertFalse(result.isUsed());
    }

    @Test
    void shouldDeleteCode() {
        redisLoginHandoffService.delete("CODE123");

        verify(redisTemplate)
                .delete("handoff:CODE123");
    }
}
