            "urn:ietf:params:scim:api:messages:2.0:PatchOp";

    public PartnersBEAP74737Get200ResponseResourcesInner toPingUser(
            UserEntity user
    ) {
        Objects.requireNonNull(user, "User must not be null");

        PartnersBEAP74737Get200ResponseResourcesInner request =
