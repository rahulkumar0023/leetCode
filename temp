    @Test
    void handleCallback_shouldCreateSessionAndReturnAuthResult() {
        mockCallbackDependencies(validTokenResponse());

        JwtUserClaims claims = new JwtUserClaims();
        claims.setSub("subject-123");
        claims.setPreferredUsername("testuser");

        when(jwtService.extractClaims("id-token")).thenReturn(claims);
        when(partnerRepositoryClient.getUserById("testuser")).thenReturn(validUser());

        AuthResult result = authService.handleCallback("auth-code", "state-123");

        assertThat(result.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(result.getSessionId()).isNotBlank();

        ArgumentCaptor<UserSession> sessionCaptor = ArgumentCaptor.forClass(UserSession.class);
        verify(redisSessionService).save(sessionCaptor.capture());

        UserSession session = sessionCaptor.getValue();
        assertThat(session.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(session.getUserId()).isEqualTo("testuser");
        assertThat(session.getUsername()).isEqualTo("testuser");
        assertThat(session.getAccessToken()).isEqualTo("access-token");
        assertThat(session.getRefreshToken()).isEqualTo("refresh-token");
        assertThat(session.getSalesPoints()).hasSize(1);

        verify(redisAuthTransactionService).delete("state-123");
    }

