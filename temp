Because some `v007` changesets have already run, **do not edit or reuse them**. Create a new version to avoid Liquibase checksum/version collisions.

Use:

```text
db/changelog/v008/008-as400-user-import-fix.yaml
```

This version:

* removes any leftover staging table;
* recreates it cleanly;
* reloads the CSV;
* imports without nonexistent `created_at` or `updated_at` columns;
* uses your real table names;
* removes duplicate relationships before ensuring the unique constraint exists;
* drops the staging table after success.

## `008-as400-user-import-fix.yaml`

```yaml
databaseChangeLog:

  # ---------------------------------------------------------------------------
  # 1. Remove any staging table left by the failed V007 execution
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-01-drop-existing-as400-staging
      author: rahul.kumar
      dbms: postgresql

      preConditions:
        onFail: MARK_RAN
        onError: HALT
        tableExists:
          tableName: as400_user_import_staging

      changes:
        - dropTable:
            tableName: as400_user_import_staging


  # ---------------------------------------------------------------------------
  # 2. Remove duplicate existing relationships
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-02-remove-duplicate-relationships
      author: rahul.kumar
      dbms: postgresql

      preConditions:
        onFail: HALT
        onError: HALT
        tableExists:
          tableName: person_sales_point_relationships

      changes:
        - sql:
            sql: |
              DELETE FROM person_sales_point_relationships
              WHERE ctid IN (
                  SELECT duplicate_ctid
                  FROM (
                      SELECT
                          ctid AS duplicate_ctid,
                          ROW_NUMBER() OVER (
                              PARTITION BY
                                  person_user_id,
                                  sales_point_id,
                                  relationship_type
                              ORDER BY ctid
                          ) AS row_number
                      FROM person_sales_point_relationships
                  ) duplicate_rows
                  WHERE row_number > 1
              );


  # ---------------------------------------------------------------------------
  # 3. Ensure the relationship unique constraint exists
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-03-add-relationship-unique-constraint
      author: rahul.kumar
      dbms: postgresql

      preConditions:
        onFail: MARK_RAN
        onError: HALT
        not:
          uniqueConstraintExists:
            tableName: person_sales_point_relationships
            constraintName: uk_person_sales_point_relationship

      changes:
        - addUniqueConstraint:
            tableName: person_sales_point_relationships
            columnNames: person_user_id, sales_point_id, relationship_type
            constraintName: uk_person_sales_point_relationship


  # ---------------------------------------------------------------------------
  # 4. Create a clean staging table
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-04-create-as400-user-import-staging
      author: rahul.kumar
      dbms: postgresql

      changes:
        - createTable:
            tableName: as400_user_import_staging
            columns:
              - column:
                  name: entity
                  type: varchar(100)

              - column:
                  name: source_record_type
                  type: varchar(50)

              - column:
                  name: related_parent
                  type: varchar(255)

              - column:
                  name: source_personal_id
                  type: varchar(255)

              - column:
                  name: gps_group_number
                  type: varchar(255)

              - column:
                  name: source_point_of_sales_id
                  type: varchar(255)

              - column:
                  name: first_name
                  type: varchar(100)

              - column:
                  name: surname
                  type: varchar(100)

              - column:
                  name: email
                  type: varchar(255)

              - column:
                  name: phone_number
                  type: varchar(50)

              - column:
                  name: language
                  type: varchar(20)

              - column:
                  name: user_status
                  type: varchar(20)

              - column:
                  name: sales_point_id
                  type: varchar(255)

              - column:
                  name: sales_point_name
                  type: varchar(255)

              - column:
                  name: relationship_type
                  type: varchar(50)

              - column:
                  name: relationship_status
                  type: varchar(20)

              - column:
                  name: imported_at
                  type: timestamp with time zone
                  defaultValueComputed: CURRENT_TIMESTAMP

      rollback:
        - dropTable:
            tableName: as400_user_import_staging


  # ---------------------------------------------------------------------------
  # 5. Load the CSV
  #
  # This file is in:
  # db/changelog/v008/008-as400-user-import-fix.yaml
  #
  # CSV is in:
  # db/changelog/data/as400-users.csv
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-05-load-as400-user-csv
      author: rahul.kumar
      dbms: postgresql

      preConditions:
        onFail: HALT
        onError: HALT
        tableExists:
          tableName: as400_user_import_staging

      changes:
        - loadData:
            file: ../data/as400-users.csv
            relativeToChangelogFile: true
            tableName: as400_user_import_staging
            encoding: UTF-8
            separator: ","
            quotchar: '"'
            usePreparedStatements: true

            columns:
              - column:
                  header: entity
                  name: entity
                  type: STRING

              - column:
                  header: source_record_type
                  name: source_record_type
                  type: STRING

              - column:
                  header: related_parent
                  name: related_parent
                  type: STRING

              - column:
                  header: source_personal_id
                  name: source_personal_id
                  type: STRING

              - column:
