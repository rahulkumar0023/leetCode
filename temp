class RandomValueGeneratorTest {

    private final RandomValueGenerator generator =
            new RandomValueGenerator();

    @Test
    void shouldGenerateNonNullValue() {
        String value = generator.generate();

        assertNotNull(value);
        assertFalse(value.isBlank());
    }

    @Test
    void shouldGenerateDifferentValuesEachTime() {
        String first = generator.generate();
        String second = generator.generate();

        assertNotEquals(first, second);
    }

    @Test
    void shouldGenerateBase64UrlSafeString() {
        String value = generator.generate();

        assertFalse(value.contains("="));
        assertFalse(value.contains("+"));
        assertFalse(value.contains("/"));
    }

    @Test
    void shouldGenerateExpectedLength() {
        String value = generator.generate();

        // 32 bytes → base64 url ≈ 43 chars (no padding)
        assertTrue(value.length() >= 40);
        assertTrue(value.length() <= 50);
    }
}
