```

Example mapper:

```java
@Component
public class PingUserMapper {

    public PartnersBEAP74737 toCreateRequest(UserEntity user) {
        PartnersBEAP74737 request = new PartnersBEAP74737();

        request.setGivenName(user.getFirstName());
        request.setSn(user.getLastName());
        request.setCn(buildCommonName(user));
        request.setMail(user.getEmail());
        request.setMobile(user.getPhoneNumber());
        request.setStatus(mapStatus(user.getStatus()));

        return request;
    }

    private String buildCommonName(UserEntity user) {
        return Stream.of(user.getFirstName(), user.getLastName())
                .filter(value -> value != null && !value.isBlank())
                .collect(Collectors.joining(" "));
    }

    private String mapStatus(String status) {
        if (status == null) {
            return null;
        }

        return switch (status.toUpperCase(Locale.ROOT)) {
            case "ACTIVE" -> "ACTIVE";
            case "INACTIVE", "DISABLED", "DELETED" -> "INACTIVE";
            default -> throw new IllegalArgumentException(
                    "Unsupported Ping user status: " + status
            );
        };
    }
}
```

Imports:

```java
