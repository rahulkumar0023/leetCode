# 8. AS400 controller

```java
package com.bnpp.pf.partner.repository.controller;

import com.bnpp.pf.partner.repository.dto.as400.As400SyncResponse;
import com.bnpp.pf.partner.repository.dto.as400.As400UserSnapshotRequest;
import com.bnpp.pf.partner.repository.service.UserSynchronizationService;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import jakarta.validation.Valid;
import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/internal/users")
@RequiredArgsConstructor
public class As400UserSyncController {

    private final UserSynchronizationService userSynchronizationService;

    @Operation(
            summary = "Create, update, or deactivate a user snapshot from AS400",
            description = """
                    Receives an AS400 person, point-of-sale, and working-relationship snapshot.
                    Partner Repository determines whether the record must be created,
                    updated, deactivated, or ignored because no change exists.
                    """
    )
    @ApiResponses({
            @ApiResponse(responseCode = "200", description = "Snapshot processed"),
            @ApiResponse(responseCode = "400", description = "Invalid snapshot payload"),
            @ApiResponse(responseCode = "500", description = "Technical processing error")
    })
    @PostMapping("/snapshots")
    public ResponseEntity<As400SyncResponse> synchronizeUser(
            @Valid @RequestBody As400UserSnapshotRequest request) {

        return ResponseEntity.ok(
                userSynchronizationService.synchronize(request));
    }
}
