@Test
void shouldHandleCallbackSuccessfully() {

    AuthTransaction tx = new AuthTransaction();
    tx.setAppId("B2BOOST_BE");
    tx.setRedirectUri("http://arthur/callback");
    tx.setCodeVerifier("VERIFIER123");

    AppConfigResponse appConfig = validAppConfig();

    OidcMetadata metadata = new OidcMetadata();
    metadata.setTokenEndpoint(
            "http://keycloak.kubernetes.localhost/token"
    );

    Map<String, Object> tokenResponse = new HashMap<>();
    tokenResponse.put("access_token", "ACCESS123");
    tokenResponse.put("id_token", "ID123");
    tokenResponse.put("refresh_token", "REFRESH123");

    JwtUserClaims claims = new JwtUserClaims();
    claims.setSub("user-1");
    claims.setPreferredUsername("rahul");

    UserResponse user = new UserResponse();
    user.setUserId("user-1");
    user.setUsername("rahul");
    user.setRoles(List.of("ADMIN"));

    when(redisAuthTransactionService.findByState("STATE123"))
            .thenReturn(tx);

    when(lancelotClient.getApp("B2BOOST_BE"))
            .thenReturn(appConfig);

    when(oidcDiscoveryClient.loadMetadata("http://issuer"))
            .thenReturn(metadata);

    /*
      Spy AuthService so we can bypass WebClient chain
    */
    AuthService spyService = spy(authService);

    doReturn(tokenResponse)
            .when(spyService)
            .exchangeToken(
                    eq("CODE123"),
                    anyString(),
                    eq(appConfig),
                    eq(tx)
            );

    when(jwtService.extractClaims("ID123"))
            .thenReturn(claims);

    when(lancelotClient.getUserById("rahul"))
            .thenReturn(user);

    AuthResult result =
            spyService.handleCallback(
                    "CODE123",
                    "STATE123"
            );

    assertNotNull(result);
    assertNotNull(result.getSessionId());
    assertEquals(
            "http://frontend/home",
            result.getPostLoginRedirectUrl()
    );
    assertNotNull(result.getHandoffCode());

    verify(redisSessionService).save(any(UserSession.class));
    verify(redisLoginHandoffService)
            .save(any(LoginHandoff.class));

    verify(redisAuthTransactionService)
            .delete("STATE123");
}
