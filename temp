Add this test class for `HandoffService`.

```java
package com.bnpp.pf.arthur.core.service;

import com.bnpp.pf.arthur.core.exception.TechnicalException;
import com.bnpp.pf.arthur.core.model.HandoffExchangeResponse;
import com.bnpp.pf.arthur.core.model.LoginHandoff;
import com.bnpp.pf.arthur.core.model.UserSession;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.time.Instant;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class HandoffServiceTest {

    @Mock
    private RedisLoginHandoffService redisLoginHandoffService;

    @Mock
    private RedisSessionService redisSessionService;

    @InjectMocks
    private HandoffService handoffService;

    @Test
    void exchange_shouldReturnResponseAndDeleteHandoff_whenCodeIsValid() {
        LoginHandoff handoff = validHandoff();
        UserSession session = validSession();

        when(redisLoginHandoffService.findByCode("code-123"))
                .thenReturn(handoff);
        when(redisSessionService.findBySessionId("session-123"))
                .thenReturn(session);

        HandoffExchangeResponse response = handoffService.exchange("code-123");

        assertThat(response.getUserId()).isEqualTo("testuser");
        assertThat(response.getUsername()).isEqualTo("testuser");
        assertThat(response.getEmail()).isEqualTo("test@test.com");
        assertThat(response.getRoles()).containsExactly("SELLER");
        assertThat(response.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(response.getSelectedSalesPointId()).isEqualTo("SP001");
        assertThat(response.getSelectedOrgUnitId()).isEqualTo("ORG001");

        verify(redisLoginHandoffService).delete("code-123");
    }

    @Test
    void exchange_shouldThrowException_whenHandoffCodeIsInvalid() {
        when(redisLoginHandoffService.findByCode("invalid-code"))
                .thenReturn(null);

        assertThatThrownBy(() -> handoffService.exchange("invalid-code"))
                .isInstanceOf(TechnicalException.class)
                .hasMessage("Invalid or expired handoff code");

        verify(redisLoginHandoffService, never()).delete("invalid-code");
        verifyNoInteractions(redisSessionService);
    }

    @Test
    void exchange_shouldThrowException_whenHandoffAlreadyUsed() {
        LoginHandoff handoff = validHandoff();
        handoff.setUsed(true);

        when(redisLoginHandoffService.findByCode("code-123"))
                .thenReturn(handoff);

        assertThatThrownBy(() -> handoffService.exchange("code-123"))
                .isInstanceOf(TechnicalException.class)
                .hasMessage("Handoff code already used");

        verify(redisLoginHandoffService, never()).delete("code-123");
        verifyNoInteractions(redisSessionService);
    }

    @Test
    void exchange_shouldDeleteAndThrowException_whenHandoffExpired() {
        LoginHandoff handoff = validHandoff();
        handoff.setExpiresAt(Instant.now().minusSeconds(10));

        when(redisLoginHandoffService.findByCode("code-123"))
                .thenReturn(handoff);

        assertThatThrownBy(() -> handoffService.exchange("code-123"))
                .isInstanceOf(TechnicalException.class)
                .hasMessage("Handoff code expired");

        verify(redisLoginHandoffService).delete("code-123");
        verifyNoInteractions(redisSessionService);
    }

    @Test
    void exchange_shouldDeleteAndThrowException_whenSessionNotFound() {
        LoginHandoff handoff = validHandoff();

        when(redisLoginHandoffService.findByCode("code-123"))
                .thenReturn(handoff);
        when(redisSessionService.findBySessionId("session-123"))
                .thenReturn(null);

        assertThatThrownBy(() -> handoffService.exchange("code-123"))
                .isInstanceOf(TechnicalException.class)
                .hasMessage("Session not found for handoff code");

        verify(redisLoginHandoffService).delete("code-123");
    }

    @Test
    void exchange_shouldAllowHandoff_whenExpiresAtIsNull() {
        LoginHandoff handoff = validHandoff();
        handoff.setExpiresAt(null);

        UserSession session = validSession();

        when(redisLoginHandoffService.findByCode("code-123"))
                .thenReturn(handoff);
        when(redisSessionService.findBySessionId("session-123"))
                .thenReturn(session);

        HandoffExchangeResponse response = handoffService.exchange("code-123");

        assertThat(response.getUserId()).isEqualTo("testuser");
        verify(redisLoginHandoffService).delete("code-123");
    }

    private LoginHandoff validHandoff() {
        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("code-123");
        handoff.setSessionId("session-123");
        handoff.setAppId("B2BOOST_BE");
        handoff.setRedirectUrl("http://localhost:8081/post-login");
        handoff.setCreatedAt(Instant.now());
        handoff.setExpiresAt(Instant.now().plusSeconds(60));
        handoff.setUsed(false);
        return handoff;
    }

    private UserSession validSession() {
        UserSession session = new UserSession();
        session.setSessionId("session-123");
        session.setUserId("testuser");
        session.setUsername("testuser");
        session.setEmail("test@test.com");
        session.setRoles(List.of("SELLER"));
        session.setAppId("B2BOOST_BE");
        session.setSelectedSalesPointId("SP001");
        session.setSelectedOrgUnitId("ORG001");
        return session;
    }
}
```

This covers:

```text
valid exchange
invalid code
already used code
expired code
missing session
null expiresAt
one-time delete behavior
```
