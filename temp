package com.yourcompany.batch.retry;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.batch.core.StepContribution;
import org.springframework.batch.core.scope.context.ChunkContext;
import org.springframework.batch.core.step.tasklet.Tasklet;
import org.springframework.batch.repeat.RepeatStatus;

import java.nio.file.Paths;
import java.time.Duration;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.List;
import java.util.Optional;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

@Slf4j
@RequiredArgsConstructor
public class RetryFailedTransfersTasklet implements Tasklet {

    private final CosStorageService cosStorageService;
    private final CftApiClient cftApiClient;

    private static final String FAILED_PREFIX = "failed/";
    private static final String RETRYING_PREFIX = "retrying/";

    @Override
    public RepeatStatus execute(StepContribution contribution,
                                ChunkContext chunkContext) {

        log.info("Starting retry of failed transfers");

        List<String> failedFiles = cosStorageService.listFiles(FAILED_PREFIX);

        for (String failedKey : failedFiles) {

            String fileName = Paths.get(failedKey).getFileName().toString();

            // ✅ filter only .zip.pgp + finance/miles
            if (!isValidRetryFile(fileName)) {
                continue;
            }

            Optional<LocalDate> fileDateOpt = extractDateFromFileName(fileName);

            if (!fileDateOpt.isPresent()) {
                log.warn("Skipping file (no date found): {}", fileName);
                continue;
            }

            LocalDate fileDate = fileDateOpt.get();

            String retryKey = failedKey.replaceFirst(FAILED_PREFIX, RETRYING_PREFIX);

            boolean claimed = cosStorageService.moveIfExists(failedKey, retryKey);

            if (!claimed) {
                continue;
            }

            try {
                log.info("Retrying transfer for {}", fileName);

                cftApiClient.notifyAndWaitForCompletion(
                        retryKey,
                        fileName,
                        Duration.ofSeconds(30)
                );

                // ✅ SUCCESS → cleanup ALL files with same date
                cleanupFilesWithSameDate(failedFiles, fileDate);

                // also delete current retrying file
                cosStorageService.deleteFile(retryKey);

                log.info("Retry successful for {}", fileName);

            } catch (Exception ex) {

                log.warn("Retry failed for {}", retryKey, ex);

                String failedAgain = retryKey.replaceFirst(RETRYING_PREFIX, FAILED_PREFIX);
                cosStorageService.moveFile(retryKey, failedAgain);
            }
        }

        log.info("Retry job finished");

        return RepeatStatus.FINISHED;
    }

    // =========================================================
    // ✅ HELPERS
    // =========================================================

    private boolean isValidRetryFile(String fileName) {
        return fileName.endsWith(".zip.pgp")
                && (fileName.toLowerCase().contains("finance")
                || fileName.toLowerCase().contains("miles"));
    }

    private Optional<LocalDate> extractDateFromFileName(String fileName) {
        Pattern pattern = Pattern.compile("(\\d{4}-\\d{2}-\\d{2}|\\d{8})");
        Matcher matcher = pattern.matcher(fileName);

        if (matcher.find()) {
            String dateStr = matcher.group();

            try {
                if (dateStr.contains("-")) {
                    return Optional.of(LocalDate.parse(dateStr));
                } else {
                    return Optional.of(LocalDate.parse(dateStr, DateTimeFormatter.BASIC_ISO_DATE));
                }
            } catch (Exception e) {
                return Optional.empty();
            }
        }
        return Optional.empty();
    }

    private void cleanupFilesWithSameDate(List<String> allFiles, LocalDate targetDate) {

        for (String key : allFiles) {

            String fileName = Paths.get(key).getFileName().toString();

            Optional<LocalDate> fileDateOpt = extractDateFromFileName(fileName);

            if (fileDateOpt.isPresent() && fileDateOpt.get().equals(targetDate)) {
                try {
                    cosStorageService.deleteFile(key);
                    log.info("Deleted related file: {}", key);
                } catch (Exception e) {
                    log.warn("Failed to delete {}", key, e);
                }
            }
        }
    }
}
