@ExtendWith(MockitoExtension.class)
class OidcDiscoveryClientTest {

    @Mock
    private WebClient webClient;

    @Mock
    private WebClient.RequestHeadersUriSpec<?> uriSpec;

    @Mock
    private WebClient.RequestHeadersSpec<?> headersSpec;

    @Mock
    private WebClient.ResponseSpec responseSpec;

    private OidcDiscoveryClient oidcDiscoveryClient;

    @BeforeEach
    void setup() {
        oidcDiscoveryClient = new OidcDiscoveryClient(webClient);
    }

    @Test
    void shouldLoadMetadataSuccessfully() {
        OidcMetadata metadata = new OidcMetadata();
        metadata.setAuthorizationEndpoint("http://auth");
        metadata.setTokenEndpoint("http://token");

        when(webClient.get()).thenReturn(uriSpec);
        when(uriSpec.uri(
                "https://issuer/.well-known/openid-configuration"))
                .thenReturn(headersSpec);
        when(headersSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.bodyToMono(OidcMetadata.class))
                .thenReturn(Mono.just(metadata));

        OidcMetadata result =
                oidcDiscoveryClient.loadMetadata("https://issuer");

        assertNotNull(result);
        assertEquals("http://auth",
                result.getAuthorizationEndpoint());
        assertEquals("http://token",
                result.getTokenEndpoint());
    }

    @Test
    void shouldThrowWhenIssuerUriIsNull() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> oidcDiscoveryClient.loadMetadata(null)
        );

        assertEquals("issuerUri must not be blank",
                ex.getMessage());
    }

    @Test
    void shouldThrowWhenIssuerUriIsBlank() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> oidcDiscoveryClient.loadMetadata(" ")
        );

        assertEquals("issuerUri must not be blank",
                ex.getMessage());
    }

    @Test
    void shouldPropagateWebClientError() {
        when(webClient.get()).thenReturn(uriSpec);
        when(uriSpec.uri(
                "https://issuer/.well-known/openid-configuration"))
                .thenReturn(headersSpec);
        when(headersSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.bodyToMono(OidcMetadata.class))
                .thenReturn(Mono.error(
                        new RuntimeException("Connection failed")));

        RuntimeException ex = assertThrows(
                RuntimeException.class,
                () -> oidcDiscoveryClient
                        .loadMetadata("https://issuer")
        );

        assertEquals("Connection failed", ex.getMessage());
    }
}
