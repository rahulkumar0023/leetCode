public UserResponse getUserById(String userId) {
    log.info("Calling Lancelot getUserById userId={}", userId);

    return lancelotWebClient.get()
            .uri("/users/{userId}", userId)
            .retrieve()
            .bodyToMono(UserResponse.class)
            .block();
}
