                  header: phone_number
                  name: phone_number
                  type: STRING

              - column:
                  header: language
                  name: language
                  type: STRING

              - column:
                  header: user_status
                  name: user_status
                  type: STRING

              - column:
                  header: sales_point_id
                  name: sales_point_id
                  type: STRING

              - column:
                  header: sales_point_name
                  name: sales_point_name
                  type: STRING

              - column:
                  header: relationship_type
                  name: relationship_type
                  type: STRING

              - column:
                  header: relationship_status
                  name: relationship_status
                  type: STRING


  # ---------------------------------------------------------------------------
  # 6. Insert or update users
  #
  # No created_at or updated_at columns are used.
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-06-upsert-users
      author: rahul.kumar
      dbms: postgresql

      changes:
        - sql:
            sql: |
              INSERT INTO users (
                  user_id,
                  username,
                  gps_group_number,
                  source_personal_id,
                  entity,
                  first_name,
                  last_name,
                  email,
                  phone_number,
                  language,
                  status
              )
              SELECT DISTINCT ON (BTRIM(gps_group_number))
                  BTRIM(gps_group_number) AS user_id,
                  BTRIM(gps_group_number) AS username,
                  BTRIM(gps_group_number) AS gps_group_number,
                  BTRIM(source_personal_id) AS source_personal_id,
                  BTRIM(entity) AS entity,
                  BTRIM(first_name) AS first_name,
                  BTRIM(surname) AS last_name,
                  NULLIF(BTRIM(email), '') AS email,
                  NULLIF(BTRIM(phone_number), '') AS phone_number,
                  NULLIF(BTRIM(language), '') AS language,
                  BTRIM(user_status) AS status
              FROM as400_user_import_staging
              WHERE gps_group_number IS NOT NULL
                AND BTRIM(gps_group_number) <> ''
              ORDER BY
                  BTRIM(gps_group_number),
                  imported_at DESC

              ON CONFLICT (user_id)
              DO UPDATE SET
                  username = EXCLUDED.username,
                  gps_group_number = EXCLUDED.gps_group_number,
                  source_personal_id = EXCLUDED.source_personal_id,
                  entity = EXCLUDED.entity,
                  first_name = EXCLUDED.first_name,
                  last_name = EXCLUDED.last_name,
                  email = EXCLUDED.email,
                  phone_number = EXCLUDED.phone_number,
                  language = EXCLUDED.language,
                  status = EXCLUDED.status;


  # ---------------------------------------------------------------------------
  # 7. Insert or update sales points
  #
  # No created_at or updated_at columns are used.
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-07-upsert-sales-points
      author: rahul.kumar
      dbms: postgresql

      changes:
        - sql:
            sql: |
              INSERT INTO sales_points (
                  sales_point_id,
                  label,
                  org_unit_id,
                  entity
              )
              SELECT DISTINCT ON (BTRIM(sales_point_id))
                  BTRIM(sales_point_id) AS sales_point_id,
                  BTRIM(sales_point_name) AS label,
                  COALESCE(
                      NULLIF(BTRIM(source_point_of_sales_id), ''),
                      BTRIM(sales_point_id)
                  ) AS org_unit_id,
                  BTRIM(entity) AS entity
              FROM as400_user_import_staging
              WHERE sales_point_id IS NOT NULL
                AND BTRIM(sales_point_id) <> ''
              ORDER BY
                  BTRIM(sales_point_id),
                  imported_at DESC

              ON CONFLICT (sales_point_id)
              DO UPDATE SET
                  label = EXCLUDED.label,
                  org_unit_id = EXCLUDED.org_unit_id,
                  entity = EXCLUDED.entity;


  # ---------------------------------------------------------------------------
  # 8. Insert or update user-sales-point relationships
  #
  # No created_at or updated_at columns are used.
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-08-upsert-user-sales-point-relationships
      author: rahul.kumar
      dbms: postgresql

      changes:
        - sql:
            sql: |
              INSERT INTO person_sales_point_relationships (
                  person_user_id,
                  sales_point_id,
                  relationship_type,
                  org_unit_id,
                  status,
                  parent_dealer_id
              )
              SELECT DISTINCT
                  BTRIM(gps_group_number) AS person_user_id,
                  BTRIM(sales_point_id) AS sales_point_id,
                  UPPER(BTRIM(relationship_type))
                      AS relationship_type,
                  BTRIM(sales_point_id) AS org_unit_id,
                  UPPER(BTRIM(relationship_status))
                      AS status,
                  NULLIF(BTRIM(related_parent), '')
                      AS parent_dealer_id
              FROM as400_user_import_staging
              WHERE gps_group_number IS NOT NULL
                AND BTRIM(gps_group_number) <> ''
                AND sales_point_id IS NOT NULL
                AND BTRIM(sales_point_id) <> ''
                AND relationship_type IS NOT NULL
                AND BTRIM(relationship_type) <> ''

              ON CONFLICT (
                  person_user_id,
                  sales_point_id,
                  relationship_type
              )
              DO UPDATE SET
                  org_unit_id = EXCLUDED.org_unit_id,
                  status = EXCLUDED.status,
                  parent_dealer_id = EXCLUDED.parent_dealer_id;


  # ---------------------------------------------------------------------------
  # 9. Drop the staging table after successful import
  # ---------------------------------------------------------------------------
  - changeSet:
      id: 008-09-drop-as400-user-import-staging
      author: rahul.kumar
      dbms: postgresql

      changes:
        - dropTable:
            tableName: as400_user_import_staging
