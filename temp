package com.bnpp.pf.partner.repository.controller;

import com.bnpp.pf.partner.repository.dto.AppConfigResponse;
import com.bnpp.pf.partner.repository.service.AppConfigService;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import java.util.List;

import static org.mockito.Mockito.when;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(AppController.class)
class AppControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockitoBean
    private AppConfigService appConfigService;

    @Test
    void getApp_shouldReturnAppConfig() throws Exception {
        AppConfigResponse response = new AppConfigResponse();
        response.setAppId("B2BOOST_BE");
        response.setEnabled(true);
        response.setClientId("client-id");
        response.setClientSecret("secret");
        response.setIssuerUri("issuer-uri");
        response.setRedirectUri("redirect-uri");
        response.setScopes(List.of("openid", "profile", "email"));
        response.setPostLoginRedirectUrl("post-login-url");
        response.setCookieName("ARTHUR_SESSION");
        response.setSessionTtlSeconds(3600);

        when(appConfigService.getApp("B2BOOST_BE")).thenReturn(response);

        mockMvc.perform(get("/apps/B2BOOST_BE"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.appId").value("B2BOOST_BE"))
                .andExpect(jsonPath("$.enabled").value(true))
                .andExpect(jsonPath("$.clientId").value("client-id"))
                .andExpect(jsonPath("$.scopes[0]").value("openid"))
                .andExpect(jsonPath("$.scopes[1]").value("profile"))
                .andExpect(jsonPath("$.scopes[2]").value("email"))
                .andExpect(jsonPath("$.sessionTtlSeconds").value(3600));
    }
}
```

