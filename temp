@ExtendWith(MockitoExtension.class)
class RetryFailedTransfersTaskletTest {

    @Mock
    private CosStorageService cosStorageService;

    @Mock
    private CftApiClient cftApiClient;

    @InjectMocks
    private RetryFailedTransfersTasklet tasklet;

    @Test
    void shouldRetryOnlyFinanceAndMilesZipPgpFiles() throws Exception {

        List<String> files = List.of(
                "failed/finance_20240101_a.zip.pgp",
                "failed/miles_20240101_b.zip.pgp",
                "failed/other_20240101_c.zip.pgp",
                "failed/finance_20240101.txt"
        );

        when(cosStorageService.listFiles("failed/")).thenReturn(files);
        when(cosStorageService.moveIfExists(any(), any())).thenReturn(true);

        tasklet.execute(null, null);

        verify(cftApiClient, times(2))
                .notifyAndWaitForCompletion(any(), any(), any());
    }

    @Test
    void shouldCleanupFilesWithSameDateOnSuccess() throws Exception {

        List<String> files = List.of(
                "failed/finance_20240101_a.zip.pgp",
                "failed/miles_20240101_b.zip.pgp",
                "failed/finance_20240102_c.zip.pgp"
        );

        when(cosStorageService.listFiles("failed/"))
                .thenReturn(files); // first call
        when(cosStorageService.moveIfExists(any(), any())).thenReturn(true);

        tasklet.execute(null, null);

        verify(cosStorageService).deleteFile("failed/finance_20240101_a.zip.pgp");
        verify(cosStorageService).deleteFile("failed/miles_20240101_b.zip.pgp");
    }

    @Test
    void shouldMoveBackToFailedOnRetryFailure() throws Exception {

        List<String> files = List.of("failed/finance_20240101_a.zip.pgp");

        when(cosStorageService.listFiles("failed/")).thenReturn(files);
        when(cosStorageService.moveIfExists(any(), any())).thenReturn(true);

        doThrow(new RuntimeException("CFT error"))
                .when(cftApiClient)
                .notifyAndWaitForCompletion(any(), any(), any());

        tasklet.execute(null, null);

        verify(cosStorageService)
                .moveFile(contains("retrying/"), contains("failed/"));
    }

    @Test
    void shouldSkipIfMoveNotClaimed() throws Exception {

        List<String> files = List.of("failed/finance_20240101_a.zip.pgp");

        when(cosStorageService.listFiles("failed/")).thenReturn(files);
        when(cosStorageService.moveIfExists(any(), any())).thenReturn(false);

        tasklet.execute(null, null);

        verifyNoInteractions(cftApiClient);
    }
}
