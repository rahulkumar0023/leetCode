public class PingUserClient {

    private final PartnersBEAP74737ResourceTypeApi pingApi;
    private final PingUserMapper pingUserMapper;

    public PartnersBEAP74737 createUser(UserEntity user) {
        PartnersBEAP74737 request =
                pingUserMapper.toPingUser(user);

        try {
            return pingApi.partnersBEAP74737Post(request);
        } catch (RuntimeException exception) {
            throw new PingIntegrationException(
                    "Failed to create user in Ping for userId: "
                            + user.getUserId(),
                    exception
            );
        }
    }

    public void updateUser(String pingResourceId, UserEntity user) {
        validatePingResourceId(pingResourceId);

        PartnersBEAP74737PatchRequest request =
                pingUserMapper.toPatchRequest(user);

        try {
            pingApi.partnersBEAP74737IdPatch(
                    pingResourceId,
                    request
            );
        } catch (RuntimeException exception) {
            throw new PingIntegrationException(
                    "Failed to update Ping user: " + pingResourceId,
                    exception
            );
        }
