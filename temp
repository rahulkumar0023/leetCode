```css
* {
    box-sizing: border-box;
}

html,
body {
    margin: 0;
    min-height: 100%;
    font-family: "Open Sans", Arial, sans-serif;
    background: #ffffff;
    color: #071414;
}

.status-screen {
    width: 100%;
    min-height: 100vh;
    overflow-x: hidden;
    background: #ffffff;
}

.page-header {
    height: 96px;
    padding: 16px clamp(24px, 7vw, 140px);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.logo {
    width: clamp(120px, 12vw, 160px);
    height: auto;
    display: block;
}

.language-selector {
    display: flex;
    align-items: center;
    gap: 8px;
}

.language-btn {
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: #154734;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
}

.language-btn.active {
    background: #073331;
    color: #ffffff;
}

.status-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 42vw);
    min-height: calc(100vh - 96px);
}

.status-content {
    padding: clamp(48px, 8vh, 96px) clamp(24px, 7vw, 140px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
}

.status-icon {
    width: clamp(72px, 8vw, 104px);
    height: clamp(72px, 8vw, 104px);
    margin-bottom: 32px;
}

.status-content h1 {
    margin: 0;
    max-width: 720px;
    color: #000000;
    font-size: clamp(36px, 4.2vw, 56px);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.03em;
}

.message {
    margin: 36px 0 0;
    max-width: 680px;
    color: #555555;
    font-size: clamp(16px, 1.4vw, 20px);
    line-height: 1.45;
    font-weight: 300;
}

.strong-message {
    margin: 12px 0 0;
    max-width: 680px;
    color: #111111;
    font-size: clamp(16px, 1.4vw, 20px);
    line-height: 1.45;
    font-weight: 700;
}

.continue-btn {
    margin-top: 40px;
    height: 48px;
    padding: 0 24px;
    border: 0;
    border-radius: 999px;
    background: #073331;
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
}

.btn-icon {
    width: 20px;
    height: 20px;
    fill: currentColor;
}

.right-illustration {
    position: relative;
    width: 100%;
    min-height: calc(100vh - 96px);
    overflow: hidden;
    border-top-left-radius: 40px;
    background: #154734;
}

.background-pattern {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
}

.mascot {
    position: absolute;
    z-index: 2;
    width: clamp(420px, 46vw, 620px);
    max-width: none;
    right: clamp(-40px, 4vw, 60px);
    bottom: clamp(-160px, -10vw, -70px);
}

/* Tablet */
@media (max-width: 1024px) {
    .status-container {
        grid-template-columns: minmax(0, 1fr) minmax(320px, 40vw);
    }

    .status-content {
        padding: 48px 40px;
    }

    .mascot {
        width: clamp(360px, 48vw, 540px);
        right: -48px;
        bottom: -120px;
    }
}

/* Mobile */
@media (max-width: 768px) {
    .page-header {
        height: 80px;
        padding: 16px 24px;
    }

    .status-container {
        display: flex;
        flex-direction: column;
    }

    .status-content {
        order: 1;
        padding: 40px 24px;
        justify-content: flex-start;
    }

    .status-content h1 {
        font-size: 34px;
        line-height: 1.12;
    }

    .message,
    .strong-message {
        font-size: 16px;
    }

    .right-illustration {
        order: 2;
        width: 100%;
        min-height: 360px;
        border-top-left-radius: 32px;
        border-top-right-radius: 32px;
    }

    .mascot {
        width: 360px;
        right: 50%;
        bottom: -90px;
        transform: translateX(50%);
    }
}
