### Sales point controller

```java
@Controller
@RequiredArgsConstructor
@Slf4j
@RequestMapping("/sales-points")
public class SalesPointController {

    private final AuthService authService;
    private final RedisSessionService redisSessionService;

    @GetMapping
    public ModelAndView salesPoints(
            @CookieValue("ARTHUR_SESSION") String sessionId
    ) {
        UserSession session = redisSessionService.findBySessionId(sessionId);

        ModelAndView mv = new ModelAndView("views/sales-points");
        mv.addObject("salesPoints", session.getSalesPoints());

        return mv;
    }

    @PostMapping("/select")
    public void selectSalesPoint(
            @CookieValue("ARTHUR_SESSION") String sessionId,
            @RequestParam String salesPointId,
            HttpServletResponse response
    ) throws IOException {

        String redirectUrl = authService.completeSalesPointSelection(sessionId, salesPointId);
        response.sendRedirect(redirectUrl);
    }
}
```

### `completeSalesPointSelection`

```java
public String completeSalesPointSelection(String sessionId, String salesPointId) {
    UserSession session = redisSessionService.findBySessionId(sessionId);

    SalesPointResponse selectedSalesPoint = session.getSalesPoints().stream()
            .filter(sp -> sp.getId().equals(salesPointId))
            .findFirst()
            .orElseThrow(() -> new IllegalArgumentException("Invalid sales point"));

    session.setSelectedSalesPointId(selectedSalesPoint.getId());
    session.setSelectedOrgUnitId(selectedSalesPoint.getOrgUnitId());
    session.setSelectedRelationshipType(selectedSalesPoint.getRelationshipType());

    redisSessionService.save(session);

    AppConfigResponse appConfig = partnerRepositoryClient.getApp(session.getAppId());

    String handoffCode = UUID.randomUUID().toString();

    LoginHandoff handoff = new LoginHandoff();
    handoff.setCode(handoffCode);
    handoff.setSessionId(session.getSessionId());
    handoff.setAppId(session.getAppId());
    handoff.setRedirectUrl(appConfig.getPostLoginRedirectUrl());
    handoff.setCreatedAt(Instant.now());
    handoff.setExpiresAt(Instant.now().plusSeconds(60));
    handoff.setUsed(false);

    redisLoginHandoffService.save(handoff);

    String separator = appConfig.getPostLoginRedirectUrl().contains("?") ? "&" : "?";
    return appConfig.getPostLoginRedirectUrl() + separator + "code=" + handoffCode;
}
```

