@ExtendWith(MockitoExtension.class)
class RedisSessionServiceTest {

    @Mock
    private RedisTemplate<String, Object> redisTemplate;

    @Mock
    private ValueOperations<String, Object> valueOperations;

    @InjectMocks
    private RedisSessionService redisSessionService;

    @BeforeEach
    void setup() {
        when(redisTemplate.opsForValue())
                .thenReturn(valueOperations);
    }

    @Test
    void shouldSaveSession() {
        UserSession session = new UserSession();
        session.setSessionId("SESSION123");

        redisSessionService.save(session);

        verify(valueOperations).set(
                eq("session:SESSION123"),
                eq(session),
                eq(Duration.ofMinutes(5))
        );
    }

    @Test
    void shouldFindSessionWhenStoredAsUserSession() {
        UserSession stored = new UserSession();
        stored.setSessionId("SESSION123");
        stored.setUserId("user1");

        when(valueOperations.get("session:SESSION123"))
                .thenReturn(stored);

        UserSession result =
                redisSessionService.findBySessionId("SESSION123");

        assertNotNull(result);
        assertEquals("SESSION123", result.getSessionId());
        assertEquals("user1", result.getUserId());
    }

    @Test
    void shouldReturnNullWhenSessionMissing() {
        when(valueOperations.get("session:MISSING"))
                .thenReturn(null);

        UserSession result =
                redisSessionService.findBySessionId("MISSING");

        assertNull(result);
    }

    @Test
    void shouldConvertMapValueToUserSession() {
        Map<String, Object> map = new HashMap<>();
        map.put("sessionId", "SESSION123");
        map.put("userId", "user1");
        map.put("username", "rahul");

        when(valueOperations.get("session:SESSION123"))
                .thenReturn(map);

        UserSession result =
                redisSessionService.findBySessionId("SESSION123");

        assertNotNull(result);
        assertEquals("SESSION123", result.getSessionId());
        assertEquals("user1", result.getUserId());
        assertEquals("rahul", result.getUsername());
    }

    @Test
    void shouldDeleteSession() {
        redisSessionService.delete("SESSION123");

        verify(redisTemplate)
                .delete("session:SESSION123");
    }
}
