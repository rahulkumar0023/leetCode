# sales-point.html

```html
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Sales Point Selection</title>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet"
          th:href="@{/css/sales-point.css}">
</head>
<body>

<div class="page-wrapper">

    <!-- HEADER -->
    <header class="header">

        <div class="logo-section">
            <img th:src="@{/images/cetelem-logo.png}"
                 alt="Cetelem Logo"
                 class="logo">
        </div>

        <div class="language-switcher">
            <button class="lang active">FR</button>
            <button class="lang">NL</button>
        </div>

    </header>

    <!-- MAIN CONTENT -->
    <main class="content-container">

        <!-- LEFT SIDE -->
        <section class="left-panel">

            <h1>
                Connexion à<br>
                votre espace partenaire
            </h1>

            <h2>Votre point de vente</h2>

            <p class="description">
                Vous devez choisir le point de vente dans lequel
                vous vous trouvez actuellement.
            </p>

            <form>

                <div class="radio-group">

                    <label>
                        <input type="radio"
                               name="salesPoint"
                               value="1"
                               checked>
                        Orange Shop Bruxelles Rue Neuve
                    </label>

                    <label>
                        <input type="radio"
                               name="salesPoint"
                               value="2">
                        Orange Shop Ixelles Porte de Namur
                    </label>

                    <label>
                        <input type="radio"
                               name="salesPoint"
                               value="3">
                        Orange Shop Place Louise
                    </label>

                </div>

                <button type="submit" class="confirm-btn">
                    Confirmer →
                </button>

            </form>

        </section>

        <!-- RIGHT SIDE -->
        <section class="right-panel">

            <img class="pattern-image"
                 th:src="@{/images/pattern-green.png}"
                 alt="">

            <img class="mascot-image"
                 th:src="@{/images/mascot.png}"
                 alt="Mascot">

        </section>

    </main>

</div>

</body>
</html>
```

