package com.bnpp.pf.arthur.core.controller;

import com.bnpp.pf.arthur.core.model.AuthResult;
import com.bnpp.pf.arthur.core.model.HandoffExchangeRequest;
import com.bnpp.pf.arthur.core.model.HandoffExchangeResponse;
import com.bnpp.pf.arthur.core.service.AuthService;
import com.bnpp.pf.arthur.core.service.HandoffService;
import jakarta.servlet.http.Cookie;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.ResponseEntity;

import java.io.IOException;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class AuthControllerTest {

    @Mock
    private AuthService authService;

    @Mock
    private HandoffService handoffService;

    @Mock
    private HttpServletRequest request;

    @Mock
    private HttpServletResponse response;

    @InjectMocks
    private AuthController authController;

    private AuthResult authResult;

    @BeforeEach
    void setup() {
        authResult = new AuthResult();
        authResult.setSessionId("SESSION123");
        authResult.setPostLoginRedirectUrl("http://localhost:3000/home");
        authResult.setHandoffCode("CODE999");
    }

    @Test
    void shouldStartAuthenticationUsingHeaderAppId() {
        when(authService.startAuthentication("B2BOOST_BE"))
                .thenReturn("http://ping/login");

        ResponseEntity<Void> result =
                authController.startAuthentication(
                        "B2BOOST_BE",
                        null,
                        request
                );

        assertEquals(302, result.getStatusCode().value());
        assertEquals("http://ping/login",
                result.getHeaders().getLocation().toString());

        verify(authService).startAuthentication("B2BOOST_BE");
    }

    @Test
    void shouldStartAuthenticationUsingQueryAppId() {
        when(authService.startAuthentication("B2BOOST_NL"))
                .thenReturn("http://ping/login");

        ResponseEntity<Void> result =
                authController.startAuthentication(
                        null,
                        "B2BOOST_NL",
                        request
                );

        assertEquals(302, result.getStatusCode().value());
        verify(authService).startAuthentication("B2BOOST_NL");
    }

    @Test
    void shouldThrowExceptionWhenAppIdMissing() {
        IllegalArgumentException ex =
                assertThrows(
                        IllegalArgumentException.class,
                        () -> authController.startAuthentication(
                                null,
                                null,
                                request
                        )
                );

        assertEquals(
                "APP_ID header or appId query param is empty",
                ex.getMessage()
        );
    }

    @Test
    void shouldHandleCallbackAndSetCookieAndRedirect()
            throws IOException {

        when(authService.handleCallback("abc123", "state999"))
                .thenReturn(authResult);

        authController.callback(
                "abc123",
                "state999",
                response
        );

        ArgumentCaptor<Cookie> cookieCaptor =
                ArgumentCaptor.forClass(Cookie.class);

        verify(response).addCookie(cookieCaptor.capture());

        Cookie cookie = cookieCaptor.getValue();

        assertEquals("ARTHUR_SESSION", cookie.getName());
        assertEquals("SESSION123", cookie.getValue());
        assertTrue(cookie.isHttpOnly());
        assertEquals("/", cookie.getPath());
        assertEquals(3600, cookie.getMaxAge());

        verify(response)
                .sendRedirect(
                        "http://localhost:3000/home?code=CODE999"
                );
    }

    @Test
    void shouldHandleCallbackWhenRedirectUrlAlreadyHasQueryParams()
            throws IOException {

        authResult.setPostLoginRedirectUrl(
                "http://localhost:3000/home?lang=en"
        );

        when(authService.handleCallback("abc", "xyz"))
                .thenReturn(authResult);

        authController.callback(
                "abc",
                "xyz",
                response
        );

        verify(response)
                .sendRedirect(
                        "http://localhost:3000/home?lang=en&code=CODE999"
                );
    }

    @Test
    void shouldExchangeHandoffCode() {

        HandoffExchangeRequest request =
                new HandoffExchangeRequest();

        request.setCode("CODE123");

        HandoffExchangeResponse serviceResponse =
                new HandoffExchangeResponse();

        when(handoffService.exchange("CODE123"))
                .thenReturn(serviceResponse);

        ResponseEntity<HandoffExchangeResponse> response =
                authController.exchange(request);

        assertEquals(200, response.getStatusCode().value());
        assertEquals(serviceResponse, response.getBody());

        verify(handoffService).exchange("CODE123");
    }
}
