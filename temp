class PkceServiceTest {

    private final PkceService pkceService = new PkceService();

    @Test
    void shouldGenerateCodeChallenge() {
        String result =
                pkceService.generateCodeChallenge("VERIFIER123");

        assertNotNull(result);
        assertFalse(result.isBlank());

        // Base64 URL-safe, no padding
        assertFalse(result.contains("="));
        assertFalse(result.contains("+"));
        assertFalse(result.contains("/"));
    }

    @Test
    void shouldGenerateSameChallengeForSameVerifier() {
        String first =
                pkceService.generateCodeChallenge("VERIFIER123");

        String second =
                pkceService.generateCodeChallenge("VERIFIER123");

        assertEquals(first, second);
    }

    @Test
    void shouldThrowWhenVerifierIsNull() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> pkceService.generateCodeChallenge(null)
        );

        assertEquals("codeVerifier must not be blank", ex.getMessage());
    }

    @Test
    void shouldThrowWhenVerifierIsBlank() {
        IllegalArgumentException ex = assertThrows(
                IllegalArgumentException.class,
                () -> pkceService.generateCodeChallenge(" ")
        );

        assertEquals("codeVerifier must not be blank", ex.getMessage());
    }
}
