        ArthurSecurityProperties properties =
                new ArthurSecurityProperties();

        assertThat(properties.getSession().getTtlMinutes()).isEqualTo(60);
        assertThat(properties.getHandoff().getTtlSeconds()).isEqualTo(60);
        assertThat(properties.getAuthTransaction().getTtlMinutes()).isEqualTo(5);
        assertThat(properties.getJwt()).isNotNull();
    }
}
