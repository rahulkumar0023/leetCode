    public PartnersBEAP74737IdPatchRequest toPatchRequest(UserEntity user) {
        Objects.requireNonNull(user, "User must not be null");

        PartnersBEAP74737IdPatchRequest request =
                new PartnersBEAP74737IdPatchRequest();

        request.setSchemas(List.of(SCIM_PATCH_SCHEMA));

        List<PartnersBEAP74737IdPatchRequestOperationsInner> operations =
                new ArrayList<>();

        addReplaceOperation(operations, "givenName", trimToNull(user.getFirstName()));
        addReplaceOperation(operations, "sn", trimToNull(user.getLastName()));
        addReplaceOperation(operations, "cn", buildCommonName(user));
