For these two classes:

```text
JwtService
OidcTokenService
```

I would test **JwtService fully**, but for `OidcTokenService`, I’d either use `MockWebServer` or exclude it from unit coverage if your team treats external HTTP clients as integration-tested. Best option is `MockWebServer`.

## 1. JwtServiceTest

```java
package com.bnpp.pf.arthur.core.service;

import com.bnpp.pf.arthur.core.model.JwtUserClaims;
import org.junit.jupiter.api.Test;
import org.springframework.security.oauth2.jwt.Jwt;
import org.springframework.security.oauth2.jwt.JwtDecoder;

import java.time.Instant;
import java.util.Map;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.when;

class JwtServiceTest {

    private final JwtDecoder jwtDecoder = mock(JwtDecoder.class);
    private final JwtService jwtService = new JwtService(jwtDecoder);

    @Test
    void extractClaims_shouldMapJwtClaims() {
        Jwt jwt = new Jwt(
                "id-token",
                Instant.now(),
                Instant.now().plusSeconds(300),
                Map.of("alg", "none"),
                Map.of(
                        "sub", "subject-123",
                        "preferred_username", "testuser",
                        "email", "test@test.com",
                        "given_name", "Test",
                        "family_name", "User"
                )
        );

        when(jwtDecoder.decode("id-token")).thenReturn(jwt);

        JwtUserClaims claims = jwtService.extractClaims("id-token");

        assertThat(claims.getSub()).isEqualTo("subject-123");
        assertThat(claims.getPreferredUsername()).isEqualTo("testuser");
        assertThat(claims.getEmail()).isEqualTo("test@test.com");
        assertThat(claims.getGivenName()).isEqualTo("Test");
        assertThat(claims.getFamilyName()).isEqualTo("User");
    }

    @Test
    void extractClaims_shouldReturnNullFields_whenOptionalClaimsAreMissing() {
        Jwt jwt = new Jwt(
                "id-token",
                Instant.now(),
                Instant.now().plusSeconds(300),
                Map.of("alg", "none"),
                Map.of("sub", "subject-123")
        );

        when(jwtDecoder.decode("id-token")).thenReturn(jwt);

        JwtUserClaims claims = jwtService.extractClaims("id-token");

        assertThat(claims.getSub()).isEqualTo("subject-123");
        assertThat(claims.getPreferredUsername()).isNull();
        assertThat(claims.getEmail()).isNull();
        assertThat(claims.getGivenName()).isNull();
        assertThat(claims.getFamilyName()).isNull();
    }
}
```

