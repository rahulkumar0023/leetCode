# 8. Update callback controller to redirect with handoff code

Do not forward. Redirect.

```java
package com.bnpp.pf.arthur.core.controller;

import com.bnpp.pf.arthur.core.dto.AuthResult;
import com.bnpp.pf.arthur.core.service.AuthService;
import jakarta.servlet.http.HttpServletResponse;
import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import java.io.IOException;

@RestController
@RequiredArgsConstructor
public class AuthController {

    private final AuthService authService;

    @GetMapping("/auth/callback")
    public void callback(
            @RequestParam String code,
            @RequestParam String state,
            HttpServletResponse response
    ) throws IOException {

        AuthResult result = authService.handleCallback(code, state);

        String separator = result.getRedirectUrl().contains("?") ? "&" : "?";
        String finalRedirect = result.getRedirectUrl() + separator + "code=" + result.getHandoffCode();

        response.sendRedirect(finalRedirect);
    }
}
```

