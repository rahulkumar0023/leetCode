### `status-page.html`

```html
<!DOCTYPE html>
<html lang="fr" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title th:text="${pageTitle}">Status</title>
    <link rel="stylesheet" th:href="@{/css/status-page.css}">
</head>

<body>
<main class="status-screen">
    <header class="page-header">
        <img class="logo" th:src="@{/images/cetelem-logo.svg}" alt="Cetelem">

        <div class="language-selector">
            <button type="button" class="language-btn active">FR</button>
            <button type="button" class="language-btn">NL</button>
        </div>
    </header>

    <section class="status-container">
        <section class="status-content">
            <img class="status-icon" th:src="@{${iconPath}}" alt="">

            <h1 th:utext="${title}">
                Oups, un problème<br>technique est survenu.
            </h1>

            <p class="message" th:text="${message}">
                Nous n’avons pas pu charger les données nécessaires pour le moment.
            </p>

            <p class="strong-message"
               th:if="${strongMessage != null and !#strings.isEmpty(strongMessage)}"
               th:text="${strongMessage}">
                Réessayez dans quelques minutes.
            </p>

            <form th:if="${showButton}" method="post" th:action="@{/sales-points/continue}">
                <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}">
                <input type="hidden" name="appId" th:value="${appId}">

                <button type="submit" class="continue-btn">
                    <span th:text="${buttonText}">Continuer</span>

                    <svg class="btn-icon"
                         xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 -960 960 960"
                         fill="currentColor">
                        <path d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"/>
                    </svg>
                </button>
            </form>
        </section>

        <section class="right-illustration">
            <img class="background-pattern"
                 th:src="@{/images/green-background.png}"
                 alt="">

            <img class="mascot"
                 th:src="@{/images/mascot.png}"
                 alt="">
        </section>
    </section>
</main>
</body>
</html>
```

