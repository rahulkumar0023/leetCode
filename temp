public boolean moveIfExists(String sourceKey, String targetKey) {

    try {
        if (!cosClient.doesObjectExist(bucketName, sourceKey)) {
            return false;
        }

        cosClient.copyObject(bucketName, sourceKey, bucketName, targetKey);
        cosClient.deleteObject(bucketName, sourceKey);

        return true;

    } catch (Exception e) {
        log.warn("Failed to move {} -> {}", sourceKey, targetKey, e);
        return false;
    }
}
