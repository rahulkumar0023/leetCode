# 4. Configure the generated API client

The generated client probably contains an `ApiClient` class. Use its actual generated package.

```java
package com.bnpp.pf.partner.repository.ping.client;

import com.bnpp.pf.partner.repository.ping.config.PingScimProperties;
import com.bnpp.pf.partner.repository.ping.generated.api.PartnersBEAP74737ResourceTypeApi;
import com.bnpp.pf.partner.repository.ping.generated.invoker.ApiClient;

import org.springframework.boot.context.properties.EnableConfigurationProperties;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.util.StringUtils;

@Configuration
@EnableConfigurationProperties(PingScimProperties.class)
public class PingClientConfiguration {

    @Bean
    ApiClient pingApiClient(PingScimProperties properties) {
        ApiClient apiClient = new ApiClient();
        apiClient.setBasePath(properties.baseUrl());

        configureAuthentication(apiClient, properties);

        return apiClient;
    }

    @Bean
    PartnersBEAP74737ResourceTypeApi partnersApi(ApiClient pingApiClient) {
        return new PartnersBEAP74737ResourceTypeApi(pingApiClient);
    }

    private void configureAuthentication(
            ApiClient apiClient,
            PingScimProperties properties
    ) {
        if (StringUtils.hasText(properties.bearerToken())) {
            apiClient.setBearerToken(properties.bearerToken());
            return;
        }

        if (StringUtils.hasText(properties.username())) {
            apiClient.setUsername(properties.username());
            apiClient.setPassword(properties.password());
        }
    }
}
```

The generated `ApiClient` may instead provide methods such as:

```java
apiClient.setAccessToken(...)
apiClient.setApiKey(...)
apiClient.setApiKeyPrefix("Bearer")
```

Use whichever methods exist in your generated class.

For example:

```java
apiClient.setApiKey(properties.bearerToken());
apiClient.setApiKeyPrefix("Bearer");
