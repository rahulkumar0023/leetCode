Add three unit tests for `moveIfExists(...)` to cover all branches:

* source does not exist → returns `false`
* source exists and move succeeds → returns `true`
* client throws exception → returns `false`

Here’s a copy-paste-ready test class:

```java
package com.bnpp.pf.einvoice.connect.cos.service;

import com.amazonaws.services.s3.AmazonS3;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.test.util.ReflectionTestUtils;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.Mockito.doThrow;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class CosStorageServiceTest {

    @Mock
    private AmazonS3 s3Client;

    @InjectMocks
    private CosStorageService cosStorageService;

    @BeforeEach
    void setUp() {
        ReflectionTestUtils.setField(cosStorageService, "bucketName", "test-bucket");
    }

    @Test
    void moveIfExists_shouldReturnFalse_whenSourceDoesNotExist() {
        String sourceKey = "failed/file.zip.pgp";
        String targetKey = "retrying/file.zip.pgp";

        when(s3Client.doesObjectExist("test-bucket", sourceKey)).thenReturn(false);

        boolean result = cosStorageService.moveIfExists(sourceKey, targetKey);

        assertThat(result).isFalse();
        verify(s3Client).doesObjectExist("test-bucket", sourceKey);
        verify(s3Client, never()).copyObject("test-bucket", sourceKey, "test-bucket", targetKey);
        verify(s3Client, never()).deleteObject("test-bucket", sourceKey);
    }

    @Test
    void moveIfExists_shouldCopyAndDeleteAndReturnTrue_whenSourceExists() {
        String sourceKey = "failed/file.zip.pgp";
        String targetKey = "retrying/file.zip.pgp";

        when(s3Client.doesObjectExist("test-bucket", sourceKey)).thenReturn(true);

        boolean result = cosStorageService.moveIfExists(sourceKey, targetKey);

        assertThat(result).isTrue();
        verify(s3Client).doesObjectExist("test-bucket", sourceKey);
        verify(s3Client).copyObject("test-bucket", sourceKey, "test-bucket", targetKey);
        verify(s3Client).deleteObject("test-bucket", sourceKey);
    }

    @Test
    void moveIfExists_shouldReturnFalse_whenExceptionOccurs() {
        String sourceKey = "failed/file.zip.pgp";
        String targetKey = "retrying/file.zip.pgp";

        when(s3Client.doesObjectExist("test-bucket", sourceKey)).thenReturn(true);
        doThrow(new RuntimeException("S3 copy failed"))
                .when(s3Client)
                .copyObject("test-bucket", sourceKey, "test-bucket", targetKey);

        boolean result = cosStorageService.moveIfExists(sourceKey, targetKey);

        assertThat(result).isFalse();
        verify(s3Client).doesObjectExist("test-bucket", sourceKey);
        verify(s3Client).copyObject("test-bucket", sourceKey, "test-bucket", targetKey);
        verify(s3Client, never()).deleteObject("test-bucket", sourceKey);
    }
}
```

A couple of notes:

* I used `AmazonS3` because your code shows `doesObjectExist`, `copyObject`, and `deleteObject`, which matches that client style.
* If your field name is not exactly `bucketName`, change the `ReflectionTestUtils.setField(...)` line.
* This should cover the red lines in `moveIfExists(...)` from your screenshot.

