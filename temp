# Step 9: Redis services

## Auth transaction service

```java
package com.yourcompany.arthurcore.service;

import com.yourcompany.arthurcore.model.AuthTransaction;
import java.util.concurrent.TimeUnit;
import lombok.RequiredArgsConstructor;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.stereotype.Service;

@Service
@RequiredArgsConstructor
public class RedisAuthTransactionService {

    private static final String PREFIX = "auth:state:";
    private final RedisTemplate<String, Object> redisTemplate;

    @Value("${auth.state.ttl-seconds}")
    private long ttlSeconds;

    public void save(AuthTransaction transaction) {
        redisTemplate.opsForValue()
                .set(PREFIX + transaction.getState(), transaction, ttlSeconds, TimeUnit.SECONDS);
    }

    public AuthTransaction findByState(String state) {
        Object value = redisTemplate.opsForValue().get(PREFIX + state);
        if (value instanceof AuthTransaction transaction) {
            return transaction;
        }
        return null;
    }

    public void delete(String state) {
        redisTemplate.delete(PREFIX + state);
    }
}
```

