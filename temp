# 10. Integrate it into the user snapshot service

A clean synchronous first version:

```java
package com.bnpp.pf.partner.repository.service;

import java.time.Instant;

import com.bnpp.pf.partner.repository.entity.PingSyncStatus;
import com.bnpp.pf.partner.repository.entity.UserEntity;
import com.bnpp.pf.partner.repository.ping.client.PingUserClient;
import com.bnpp.pf.partner.repository.ping.exception.PingIntegrationException;
import com.bnpp.pf.partner.repository.repository.UserRepository;

import lombok.RequiredArgsConstructor;

import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

@Service
@RequiredArgsConstructor
public class UserPingSynchronizationService {

    private final PingUserClient pingUserClient;
    private final UserRepository userRepository;

    @Transactional
    public void createInPing(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.PENDING);
        user.setPingLastError(null);

        try {
            var pingUser = pingUserClient.createUser(user);

            if (pingUser == null || pingUser.getId() == null) {
                throw new PingIntegrationException(
                        "Ping returned no resource id for user: "
                                + user.getUserId()
                );
            }

            user.setPingResourceId(pingUser.getId());
            markSuccess(user);

        } catch (RuntimeException exception) {
            markFailure(user, exception);
            throw exception;
        }
    }

    @Transactional
    public void updateInPing(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.PENDING);
        user.setPingLastError(null);

        try {
            pingUserClient.updateUser(
                    user.getPingResourceId(),
                    user
            );

            markSuccess(user);

        } catch (RuntimeException exception) {
            markFailure(user, exception);
            throw exception;
        }
    }

    @Transactional
    public void deleteFromPing(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.PENDING);
        user.setPingLastError(null);

        try {
            pingUserClient.deleteUser(user.getPingResourceId());

            markSuccess(user);

        } catch (RuntimeException exception) {
            markFailure(user, exception);
            throw exception;
        }
    }

    private void markSuccess(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.SUCCESS);
        user.setPingLastSyncedAt(Instant.now());
        user.setPingLastError(null);

        userRepository.save(user);
    }

    private void markFailure(
            UserEntity user,
            RuntimeException exception
    ) {
        user.setPingSyncStatus(PingSyncStatus.FAILED);
        user.setPingLastError(truncate(exception.getMessage(), 2000));

        userRepository.save(user);
    }

    private String truncate(String value, int maxLength) {
        if (value == null || value.length() <= maxLength) {
            return value;
        }

        return value.substring(0, maxLength);
    }
}
```

