            markSuccess(user);

        } catch (RuntimeException exception) {
            markFailure(user, exception);
            throw exception;
        }
    }

    @Transactional
    public void updateInPing(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.PENDING);
        user.setPingLastError(null);

        try {
            pingUserClient.updateUser(
                    user.getPingResourceId(),
                    user
            );

            markSuccess(user);

        } catch (RuntimeException exception) {
            markFailure(user, exception);
            throw exception;
        }
    }

    @Transactional
    public void deleteFromPing(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.PENDING);
        user.setPingLastError(null);

        try {
            pingUserClient.deleteUser(user.getPingResourceId());

            markSuccess(user);

        } catch (RuntimeException exception) {
            markFailure(user, exception);
            throw exception;
        }
    }

    private void markSuccess(UserEntity user) {
        user.setPingSyncStatus(PingSyncStatus.SUCCESS);
        user.setPingLastSyncedAt(Instant.now());
        user.setPingLastError(null);

        userRepository.save(user);
    }

    private void markFailure(
            UserEntity user,
            RuntimeException exception
    ) {
        user.setPingSyncStatus(PingSyncStatus.FAILED);
        user.setPingLastError(truncate(exception.getMessage(), 2000));

        userRepository.save(user);
    }

    private String truncate(String value, int maxLength) {
        if (value == null || value.length() <= maxLength) {
            return value;
        }

        return value.substring(0, maxLength);
    }
}
