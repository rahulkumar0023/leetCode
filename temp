@ExtendWith(MockitoExtension.class)
class JwtServiceTest {

    @Mock
    private JwtDecoder jwtDecoder;

    @Mock
    private Jwt jwt;

    private JwtService jwtService;

    @BeforeEach
    void setup() {
        jwtService = new JwtService(jwtDecoder);
    }

    @Test
    void shouldExtractAllClaims() {
        when(jwtDecoder.decode("TOKEN123"))
                .thenReturn(jwt);

        when(jwt.getSubject()).thenReturn("user-001");
        when(jwt.getClaimAsString("preferred_username"))
                .thenReturn("rahul");
        when(jwt.getClaimAsString("email"))
                .thenReturn("rahul@test.com");
        when(jwt.getClaimAsString("given_name"))
                .thenReturn("Rahul");
        when(jwt.getClaimAsString("family_name"))
                .thenReturn("Kumar");

        JwtUserClaims result =
                jwtService.extractClaims("TOKEN123");

        assertNotNull(result);
        assertEquals("user-001", result.getSub());
        assertEquals("rahul", result.getPreferredUsername());
        assertEquals("rahul@test.com", result.getEmail());
        assertEquals("Rahul", result.getGivenName());
        assertEquals("Kumar", result.getFamilyName());
    }

    @Test
    void shouldAllowMissingOptionalClaims() {
        when(jwtDecoder.decode("TOKEN123"))
                .thenReturn(jwt);

        when(jwt.getSubject()).thenReturn("user-001");
        when(jwt.getClaimAsString("preferred_username"))
                .thenReturn(null);
        when(jwt.getClaimAsString("email"))
                .thenReturn(null);
        when(jwt.getClaimAsString("given_name"))
                .thenReturn(null);
        when(jwt.getClaimAsString("family_name"))
                .thenReturn(null);

        JwtUserClaims result =
                jwtService.extractClaims("TOKEN123");

        assertNotNull(result);
        assertEquals("user-001", result.getSub());
        assertNull(result.getPreferredUsername());
        assertNull(result.getEmail());
        assertNull(result.getGivenName());
        assertNull(result.getFamilyName());
    }

    @Test
    void shouldThrowWhenTokenInvalid() {
        when(jwtDecoder.decode("BAD_TOKEN"))
                .thenThrow(new JwtException("Invalid token"));

        assertThrows(
                JwtException.class,
                () -> jwtService.extractClaims("BAD_TOKEN")
        );
    }
}
