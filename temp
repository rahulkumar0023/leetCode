# 7. Synchronization service

```java
package com.bnpp.pf.partner.repository.service;

import com.bnpp.pf.partner.repository.dto.as400.*;
import com.bnpp.pf.partner.repository.entity.PersonSalesPointRelationshipEntity;
import com.bnpp.pf.partner.repository.entity.SalesPointEntity;
import com.bnpp.pf.partner.repository.entity.UserEntity;
import com.bnpp.pf.partner.repository.repository.PersonSalesPointRelationshipRepository;
import com.bnpp.pf.partner.repository.repository.SalesPointRepository;
import com.bnpp.pf.partner.repository.repository.UserRepository;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.Objects;
import java.util.Optional;

@Service
@RequiredArgsConstructor
public class UserSynchronizationService {

    private final UserRepository userRepository;
    private final SalesPointRepository salesPointRepository;
    private final PersonSalesPointRelationshipRepository relationshipRepository;

    @Transactional
    public As400SyncResponse synchronize(As400UserSnapshotRequest request) {

        String correlationId = request.getMetadata().getCorrelationId();

        Optional<UserEntity> existingUser =
                userRepository.findByGpsGroupNumber(
                        request.getSource().getGpsGroupNumber());

        boolean userCreated = existingUser.isEmpty();

        UserEntity user = existingUser.orElseGet(UserEntity::new);

        if (userCreated) {
            populateNewUser(user, request);
        } else {
            updateUser(user, request);
        }

        user = userRepository.save(user);

        SalesPointEntity salesPoint = salesPointRepository
                .findBySalesPointId(request.getPointOfSales().getId())
                .orElseGet(SalesPointEntity::new);

        boolean salesPointChanged = updateSalesPoint(salesPoint, request);
        salesPointRepository.save(salesPoint);

        Optional<PersonSalesPointRelationshipEntity> existingRelationship =
                relationshipRepository
                        .findByPersonUserIdAndSalesPointIdAndRelationshipType(
                                user.getUserId(),
                                salesPoint.getSalesPointId(),
                                request.getWorkingRelationship()
                                        .getRelationshipType()
                        );

        boolean relationshipCreated = existingRelationship.isEmpty();

        PersonSalesPointRelationshipEntity relationship =
                existingRelationship.orElseGet(
                        PersonSalesPointRelationshipEntity::new);

        boolean relationshipChanged =
                updateRelationship(relationship, user, salesPoint, request);

        relationshipRepository.save(relationship);

        if (isInactive(request)) {
            return As400SyncResponse.builder()
                    .status("ACCEPTED")
                    .code(As400SyncCode.RECORD_DEACTIVATED)
                    .message("User relationship was deactivated.")
                    .correlationId(correlationId)
                    .partnerRepositoryRecordId(user.getUserId())
                    .build();
        }

        if (userCreated || relationshipCreated) {
            return As400SyncResponse.builder()
                    .status("ACCEPTED")
                    .code(As400SyncCode.RECORD_CREATED)
                    .message("User snapshot created successfully.")
                    .correlationId(correlationId)
                    .partnerRepositoryRecordId(user.getUserId())
                    .build();
        }

        if (salesPointChanged || relationshipChanged) {
            return As400SyncResponse.builder()
                    .status("ACCEPTED")
                    .code(As400SyncCode.RECORD_UPDATED)
                    .message("User snapshot updated successfully.")
                    .correlationId(correlationId)
                    .partnerRepositoryRecordId(user.getUserId())
                    .build();
        }

        return As400SyncResponse.builder()
                .status("ACCEPTED")
                .code(As400SyncCode.NO_CHANGE)
                .message("Snapshot received but no effective change was detected.")
                .correlationId(correlationId)
                .partnerRepositoryRecordId(user.getUserId())
                .build();
    }

    private void populateNewUser(
            UserEntity user,
            As400UserSnapshotRequest request) {

        String gpsGroupNumber = request.getSource().getGpsGroupNumber();

        /*
         * For now gpsGroupNumber is used as the internal user ID and username.
         * Replace this later if Ping provides a dedicated Login ID.
         */
        user.setUserId(gpsGroupNumber);
        user.setUsername(gpsGroupNumber);

        updateUser(user, request);
    }

    private void updateUser(
            UserEntity user,
            As400UserSnapshotRequest request) {

        user.setGpsGroupNumber(request.getSource().getGpsGroupNumber());
        user.setSourcePersonalId(request.getSource().getSourcePersonalId());
        user.setEntity(request.getSource().getEntity());

        user.setFirstName(request.getPerson().getFirstName());
        user.setLastName(request.getPerson().getSurname());
        user.setEmail(request.getPerson().getEmail());
        user.setPhoneNumber(request.getPerson().getPhoneNumber());
        user.setLanguage(request.getPerson().getLanguage());
        user.setStatus(request.getPerson().getStatus());
    }

    private boolean updateSalesPoint(
            SalesPointEntity salesPoint,
            As400UserSnapshotRequest request) {

        boolean changed =
                !Objects.equals(
                        salesPoint.getSalesPointId(),
                        request.getPointOfSales().getId())
                        || !Objects.equals(
                        salesPoint.getLabel(),
                        request.getPointOfSales().getName())
                        || !Objects.equals(
                        salesPoint.getOrgUnitId(),
                        request.getSource().getSourcePointOfSalesId())
                        || !Objects.equals(
                        salesPoint.getEntity(),
                        request.getSource().getEntity());

        salesPoint.setSalesPointId(request.getPointOfSales().getId());
        salesPoint.setLabel(request.getPointOfSales().getName());
        salesPoint.setOrgUnitId(
                request.getSource().getSourcePointOfSalesId());
        salesPoint.setEntity(request.getSource().getEntity());

        return changed;
    }

    private boolean updateRelationship(
            PersonSalesPointRelationshipEntity relationship,
            UserEntity user,
            SalesPointEntity salesPoint,
            As400UserSnapshotRequest request) {

        boolean changed =
                !Objects.equals(
                        relationship.getPersonUserId(),
                        user.getUserId())
                        || !Objects.equals(
                        relationship.getSalesPointId(),
                        salesPoint.getSalesPointId())
                        || !Objects.equals(
                        relationship.getRelationshipType(),
                        request.getWorkingRelationship()
                                .getRelationshipType())
                        || !Objects.equals(
                        relationship.getOrgUnitId(),
                        request.getSource().getSourcePointOfSalesId())
                        || !Objects.equals(
                        relationship.getStatus(),
                        request.getWorkingRelationship().getStatus())
                        || !Objects.equals(
                        relationship.getParentDealerId(),
                        request.getWorkingRelationship()
                                .getParentDealerId());

        relationship.setPersonUserId(user.getUserId());
        relationship.setSalesPointId(salesPoint.getSalesPointId());
        relationship.setRelationshipType(
                request.getWorkingRelationship().getRelationshipType());
        relationship.setOrgUnitId(
                request.getSource().getSourcePointOfSalesId());
        relationship.setStatus(
                request.getWorkingRelationship().getStatus());
        relationship.setParentDealerId(
                request.getWorkingRelationship().getParentDealerId());

        return changed;
    }

    private boolean isInactive(As400UserSnapshotRequest request) {
        return "INACTIVE".equals(request.getPerson().getStatus())
                || "INACTIVE".equals(
                        request.getWorkingRelationship().getStatus());
    }
}
```

