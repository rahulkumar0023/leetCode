package com.bnpp.pf.einvoice.connect.batch.tasklet;

import com.bnpp.pf.einvoice.connect.cos.service.CosStorageService;
import com.bnpp.pf.einvoice.connect.notifycft.CFTApiClient;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.batch.core.StepContribution;
import org.springframework.batch.core.scope.context.ChunkContext;
import org.springframework.batch.repeat.RepeatStatus;

import java.time.Duration;
import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.ArgumentMatchers.contains;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.atLeastOnce;
import static org.mockito.Mockito.doNothing;
import static org.mockito.Mockito.doThrow;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.verifyNoInteractions;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class RetryFailedTransfersTaskletTest {

    private static final String FAILED_PREFIX = "failed/";
    private static final String RETRYING_PREFIX = "retrying/";

    @Mock
    private CosStorageService cosStorageService;

    @Mock
    private CFTApiClient cftApiClient;

    @Mock
    private StepContribution contribution;

    @Mock
    private ChunkContext chunkContext;

    @InjectMocks
    private RetryFailedTransfersTasklet tasklet;

    @BeforeEach
    void setUp() {
        tasklet = new RetryFailedTransfersTasklet(cosStorageService, cftApiClient);
    }

    @Test
    void shouldRetryAndCleanupOnSuccess() throws Exception {
        String retryCandidate = "failed/finance_20240101.zip.pgp";
        String relatedZip = "failed/finance_20240101.zip";
        String relatedMiles = "failed/miles_20240101.zip.pgp";
        String otherDate = "failed/finance_20240102.zip.pgp";

        List<String> failedFiles = Arrays.asList(
                retryCandidate,
                relatedZip,
                relatedMiles,
                otherDate
        );

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(failedFiles);
        when(cosStorageService.moveIfExists(eq(retryCandidate), eq("retrying/finance_20240101.zip.pgp")))
                .thenReturn(true);

        doNothing().when(cftApiClient)
                .notifyAndWaitForCompletion(
                        eq("retrying/finance_20240101.zip.pgp"),
                        eq("finance_20240101.zip.pgp"),
                        any(Duration.class)
                );

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cftApiClient)
                .notifyAndWaitForCompletion(
                        eq("retrying/finance_20240101.zip.pgp"),
                        eq("finance_20240101.zip.pgp"),
                        any(Duration.class)
                );

        verify(cosStorageService).deleteFile("failed/finance_20240101.zip.pgp");
        verify(cosStorageService).deleteFile("failed/finance_20240101.zip");
        verify(cosStorageService).deleteFile("failed/miles_20240101.zip.pgp");
        verify(cosStorageService, never()).deleteFile("failed/finance_20240102.zip.pgp");

        verify(cosStorageService).deleteFile("retrying/finance_20240101.zip.pgp");
        verify(cosStorageService, never()).moveFile(anyString(), anyString());
    }

    @Test
    void shouldMoveBackToFailedOnCftFailure() throws Exception {
        String failedKey = "failed/miles_20240101.zip.pgp";
        String retryKey = "retrying/miles_20240101.zip.pgp";

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(Collections.singletonList(failedKey));
        when(cosStorageService.moveIfExists(eq(failedKey), eq(retryKey))).thenReturn(true);

        doThrow(new RuntimeException("CFT failed"))
                .when(cftApiClient)
                .notifyAndWaitForCompletion(
                        eq(retryKey),
                        eq("miles_20240101.zip.pgp"),
                        any(Duration.class)
                );

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cftApiClient)
                .notifyAndWaitForCompletion(
                        eq(retryKey),
                        eq("miles_20240101.zip.pgp"),
                        any(Duration.class)
                );

        verify(cosStorageService).moveFile(retryKey, failedKey);
        verify(cosStorageService, never()).deleteFile(anyString());
    }

    @Test
    void shouldIgnoreNonZipPgpFiles() throws Exception {
        List<String> failedFiles = Arrays.asList(
                "failed/finance_20240101.zip",
                "failed/miles_20240101.xml",
                "failed/miles_20240101.pdf"
        );

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(failedFiles);

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveIfExists(anyString(), anyString());
        verify(cosStorageService, never()).moveFile(anyString(), anyString());
        verify(cosStorageService, never()).deleteFile(anyString());
    }

    @Test
    void shouldIgnoreZipPgpFilesWithoutFinanceOrMilesInName() throws Exception {
        List<String> failedFiles = Arrays.asList(
                "failed/random_20240101.zip.pgp",
                "failed/generix_20240101.zip.pgp"
        );

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(failedFiles);

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveIfExists(anyString(), anyString());
        verify(cosStorageService, never()).moveFile(anyString(), anyString());
        verify(cosStorageService, never()).deleteFile(anyString());
    }

    @Test
    void shouldSkipFileWithoutDate() throws Exception {
        String noDateFile = "failed/finance_invalid.zip.pgp";

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(Collections.singletonList(noDateFile));

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveIfExists(anyString(), anyString());
        verify(cosStorageService, never()).moveFile(anyString(), anyString());
        verify(cosStorageService, never()).deleteFile(anyString());
    }

    @Test
    void shouldSkipIfFileNotClaimed() throws Exception {
        String failedKey = "failed/finance_20240101.zip.pgp";
        String retryKey = "retrying/finance_20240101.zip.pgp";

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(Collections.singletonList(failedKey));
        when(cosStorageService.moveIfExists(eq(failedKey), eq(retryKey))).thenReturn(false);

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verifyNoInteractions(cftApiClient);
        verify(cosStorageService, never()).moveFile(anyString(), anyString());
        verify(cosStorageService, never()).deleteFile(anyString());
    }

    @Test
    void shouldCleanupOnlySameDateFilesOnSuccess() throws Exception {
        String retryCandidate = "failed/finance_20240317.zip.pgp";
        String sameDateZip = "failed/miles_20240317.zip";
        String sameDateOther = "failed/finance_20240317_extra.xml";
        String differentDate = "failed/miles_20240318.zip.pgp";

        when(cosStorageService.listKeys(FAILED_PREFIX)).thenReturn(Arrays.asList(
                retryCandidate,
                sameDateZip,
                sameDateOther,
                differentDate
        ));
        when(cosStorageService.moveIfExists(
                eq(retryCandidate),
                eq("retrying/finance_20240317.zip.pgp")
        )).thenReturn(true);

        doNothing().when(cftApiClient)
                .notifyAndWaitForCompletion(
                        eq("retrying/finance_20240317.zip.pgp"),
                        eq("finance_20240317.zip.pgp"),
                        any(Duration.class)
                );

        RepeatStatus result = tasklet.execute(contribution, chunkContext);

        assertThat(result).isEqualTo(RepeatStatus.FINISHED);

        verify(cosStorageService).deleteFile("failed/finance_20240317.zip.pgp");
        verify(cosStorageService).deleteFile("failed/miles_20240317.zip");
        verify(cosStorageService).deleteFile("failed/finance_20240317_extra.xml");
        verify(cosStorageService, never()).deleteFile("failed/miles_20240318.zip.pgp");
    }
}
