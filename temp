This is the final wrapper around the generated API.

Your Maven error showed that `POST` requires:

```java
body, attributes, excludedAttributes
```

and `PATCH` requires:

```java
id, attributes, excludedAttributes, If-Match, body
```

So we pass `null` for the optional values.

```java
package com.bnpp.pf.partner.repository.ping;

import com.bnpp.pf.partner.repository.entity.UserEntity;
import com.bnpp.pf.partner.repository.ping.client.api.PartnersBeAp74737ResourceTypeApi;
import com.bnpp.pf.partner.repository.ping.client.model.PartnersBEAP74737Get200ResponseResourcesInner;
import com.bnpp.pf.partner.repository.ping.client.model.PartnersBEAP74737IdPatchRequest;

import lombok.AllArgsConstructor;

import org.springframework.stereotype.Component;

@Component
@AllArgsConstructor
public class PingUserClient {

    private final PartnersBeAp74737ResourceTypeApi pingApi;
    private final PingUserMapper pingUserMapper;

    public PartnersBEAP74737Get200ResponseResourcesInner createUser(
            UserEntity user
    ) {
        PartnersBEAP74737Get200ResponseResourcesInner request =
                pingUserMapper.toPingUser(user);

        try {
            return pingApi.partnersBEAP74737Post(
                    request,
                    null,
                    null
            );
        } catch (RuntimeException exception) {
            throw new PingIntegrationException(
                    "Failed to create user in Ping: " + user.getUserId(),
                    exception
            );
        }
    }

    public void updateUser(
            String pingResourceId,
            UserEntity user
    ) {
        validatePingResourceId(pingResourceId);

        PartnersBEAP74737IdPatchRequest request =
                pingUserMapper.toPatchRequest(user);

        try {
            pingApi.partnersBEAP74737IdPatch(
                    pingResourceId,
                    null,
                    null,
                    null,
                    request
            );
        } catch (RuntimeException exception) {
            throw new PingIntegrationException(
                    "Failed to update user in Ping: " + pingResourceId,
                    exception
            );
        }
    }

    public void deleteUser(String pingResourceId) {
        validatePingResourceId(pingResourceId);

        try {
            pingApi.partnersBEAP74737IdDelete(pingResourceId);
        } catch (RuntimeException exception) {
            throw new PingIntegrationException(
                    "Failed to delete user in Ping: " + pingResourceId,
                    exception
            );
        }
    }

    private void validatePingResourceId(String pingResourceId) {
        if (pingResourceId == null || pingResourceId.isBlank()) {
            throw new IllegalArgumentException(
                    "Ping resource id must not be empty"
            );
        }
    }
}
