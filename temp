## 2. `RedisAuthTransactionServiceTest`

```java
package com.bnpp.pf.arthur.core.service;

import com.bnpp.pf.arthur.core.exception.TechnicalException;
import com.bnpp.pf.arthur.core.model.AuthTransaction;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.data.redis.core.ValueOperations;

import java.time.Duration;
import java.util.Map;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class RedisAuthTransactionServiceTest {

    @Mock
    private RedisTemplate<String, Object> redisTemplate;

    @Mock
    private ValueOperations<String, Object> valueOperations;

    private final ObjectMapper objectMapper = new ObjectMapper();

    @Test
    void save_shouldStoreAuthTransactionWithTtl() {
        RedisAuthTransactionService service =
                new RedisAuthTransactionService(redisTemplate, objectMapper);

        AuthTransaction tx = authTransaction();

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        service.save(tx);

        verify(valueOperations).set(
                "auth:state:state-123",
                tx,
                Duration.ofMinutes(5)
        );
    }

    @Test
    void findByState_shouldReturnNull_whenValueIsNull() {
        RedisAuthTransactionService service =
                new RedisAuthTransactionService(redisTemplate, objectMapper);

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("auth:state:state-123")).thenReturn(null);

        AuthTransaction result = service.findByState("state-123");

        assertThat(result).isNull();
    }

    @Test
    void findByState_shouldReturnAuthTransaction_whenValueIsAuthTransaction() {
        RedisAuthTransactionService service =
                new RedisAuthTransactionService(redisTemplate, objectMapper);

        AuthTransaction tx = authTransaction();

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("auth:state:state-123")).thenReturn(tx);

        AuthTransaction result = service.findByState("state-123");

        assertThat(result).isSameAs(tx);
    }

    @Test
    void findByState_shouldConvertMapToAuthTransaction_whenValueIsMap() {
        RedisAuthTransactionService service =
                new RedisAuthTransactionService(redisTemplate, objectMapper);

        Map<String, Object> value = Map.of(
                "state", "state-123",
                "nonce", "nonce-123",
                "codeVerifier", "verifier-123",
                "appId", "B2BOOST_BE",
                "redirectUri", "http://localhost/callback"
        );

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("auth:state:state-123")).thenReturn(value);

        AuthTransaction result = service.findByState("state-123");

        assertThat(result.getState()).isEqualTo("state-123");
        assertThat(result.getNonce()).isEqualTo("nonce-123");
        assertThat(result.getCodeVerifier()).isEqualTo("verifier-123");
        assertThat(result.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(result.getRedirectUri()).isEqualTo("http://localhost/callback");
    }

    @Test
    void findByState_shouldThrowException_whenValueTypeIsUnexpected() {
        RedisAuthTransactionService service =
                new RedisAuthTransactionService(redisTemplate, objectMapper);

        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
        when(valueOperations.get("auth:state:state-123")).thenReturn("unexpected");

        assertThatThrownBy(() -> service.findByState("state-123"))
                .isInstanceOf(TechnicalException.class)
                .hasMessageContaining("Unexpected auth transaction type");
    }

    @Test
    void delete_shouldDeleteAuthTransactionByState() {
        RedisAuthTransactionService service =
                new RedisAuthTransactionService(redisTemplate, objectMapper);

        service.delete("state-123");

        verify(redisTemplate).delete("auth:state:state-123");
    }

    private AuthTransaction authTransaction() {
        AuthTransaction tx = new AuthTransaction();
        tx.setState("state-123");
        tx.setNonce("nonce-123");
        tx.setCodeVerifier("verifier-123");
        tx.setAppId("B2BOOST_BE");
        tx.setRedirectUri("http://localhost/callback");
        return tx;
    }
}
```

