@ExtendWith(MockitoExtension.class)
class HandoffServiceTest {

    @Mock
    private RedisLoginHandoffService redisLoginHandoffService;

    @Mock
    private RedisSessionService redisSessionService;

    @InjectMocks
    private HandoffService handoffService;

    @Test
    void shouldExchangeHandoffCodeSuccessfully() {
        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("CODE123");
        handoff.setSessionId("SESSION123");
        handoff.setUsed(false);
        handoff.setExpiresAt(Instant.now().plusSeconds(60));

        UserSession session = new UserSession();
        session.setUserId("testuser");
        session.setUsername("testuser");
        session.setEmail("testuser@test.local");
        session.setRoles(List.of("SELLER"));
        session.setAppId("B2BOOST_BE");

        when(redisLoginHandoffService.findByCode("CODE123"))
                .thenReturn(handoff);

        when(redisSessionService.findBySessionId("SESSION123"))
                .thenReturn(session);

        HandoffExchangeResponse response =
                handoffService.exchange("CODE123");

        assertEquals("testuser", response.getUserId());
        assertEquals("testuser", response.getUsername());
        assertEquals("testuser@test.local", response.getEmail());
        assertEquals(List.of("SELLER"), response.getRoles());
        assertEquals("B2BOOST_BE", response.getAppId());

        verify(redisLoginHandoffService).delete("CODE123");
    }

    @Test
    void shouldThrowWhenHandoffCodeInvalidOrExpired() {
        when(redisLoginHandoffService.findByCode("BAD_CODE"))
                .thenReturn(null);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> handoffService.exchange("BAD_CODE")
        );

        assertEquals("Invalid or expired handoff code", ex.getMessage());
        verify(redisSessionService, never()).findBySessionId(anyString());
    }

    @Test
    void shouldThrowWhenHandoffCodeAlreadyUsed() {
        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("CODE123");
        handoff.setSessionId("SESSION123");
        handoff.setUsed(true);

        when(redisLoginHandoffService.findByCode("CODE123"))
                .thenReturn(handoff);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> handoffService.exchange("CODE123")
        );

        assertEquals("Handoff code already used", ex.getMessage());
        verify(redisSessionService, never()).findBySessionId(anyString());
    }

    @Test
    void shouldThrowAndDeleteWhenHandoffCodeExpired() {
        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("CODE123");
        handoff.setSessionId("SESSION123");
        handoff.setUsed(false);
        handoff.setExpiresAt(Instant.now().minusSeconds(60));

        when(redisLoginHandoffService.findByCode("CODE123"))
                .thenReturn(handoff);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> handoffService.exchange("CODE123")
        );

        assertEquals("Handoff code expired", ex.getMessage());

        verify(redisLoginHandoffService).delete("CODE123");
        verify(redisSessionService, never()).findBySessionId(anyString());
    }

    @Test
    void shouldThrowAndDeleteWhenSessionNotFound() {
        LoginHandoff handoff = new LoginHandoff();
        handoff.setCode("CODE123");
        handoff.setSessionId("SESSION123");
        handoff.setUsed(false);
        handoff.setExpiresAt(Instant.now().plusSeconds(60));

        when(redisLoginHandoffService.findByCode("CODE123"))
                .thenReturn(handoff);

        when(redisSessionService.findBySessionId("SESSION123"))
                .thenReturn(null);

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> handoffService.exchange("CODE123")
        );

        assertEquals("Session not found for handoff code", ex.getMessage());

        verify(redisLoginHandoffService).delete("CODE123");
    }
}
