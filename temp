@ExtendWith(MockitoExtension.class)
class RedisAuthTransactionServiceTest {

    @Mock
    private RedisTemplate<String, Object> redisTemplate;

    @Mock
    private ValueOperations<String, Object> valueOperations;

    @Mock
    private ObjectMapper objectMapper;

    @InjectMocks
    private RedisAuthTransactionService redisAuthTransactionService;

    @Test
    void shouldSaveAuthTransaction() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        AuthTransaction tx = new AuthTransaction();
        tx.setState("STATE123");

        redisAuthTransactionService.save(tx);

        verify(valueOperations).set(
                eq("auth:state:STATE123"),
                eq(tx),
                eq(Duration.ofMinutes(5))
        );
    }

    @Test
    void shouldFindByStateWhenStoredAsObject() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        AuthTransaction tx = new AuthTransaction();
        tx.setState("STATE123");

        when(valueOperations.get("auth:state:STATE123"))
                .thenReturn(tx);

        AuthTransaction result =
                redisAuthTransactionService.findByState("STATE123");

        assertNotNull(result);
        assertEquals("STATE123", result.getState());
    }

    @Test
    void shouldReturnNullWhenStateMissing() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        when(valueOperations.get("auth:state:MISSING"))
                .thenReturn(null);

        AuthTransaction result =
                redisAuthTransactionService.findByState("MISSING");

        assertNull(result);
    }

    @Test
    void shouldConvertMapToAuthTransaction() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        Map<String, Object> map = new HashMap<>();
        map.put("state", "STATE123");
        map.put("appId", "B2BOOST_BE");

        AuthTransaction converted = new AuthTransaction();
        converted.setState("STATE123");
        converted.setAppId("B2BOOST_BE");

        when(valueOperations.get("auth:state:STATE123"))
                .thenReturn(map);

        when(objectMapper.convertValue(
                map,
                AuthTransaction.class
        )).thenReturn(converted);

        AuthTransaction result =
                redisAuthTransactionService.findByState("STATE123");

        assertNotNull(result);
        assertEquals("STATE123", result.getState());
        assertEquals("B2BOOST_BE", result.getAppId());
    }

    @Test
    void shouldThrowWhenUnexpectedTypeReturned() {
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);

        when(valueOperations.get("auth:state:STATE123"))
                .thenReturn("BAD_VALUE");

        IllegalStateException ex = assertThrows(
                IllegalStateException.class,
                () -> redisAuthTransactionService
                        .findByState("STATE123")
        );

        assertTrue(ex.getMessage()
                .contains("Unexpected auth transaction type"));
    }

    @Test
    void shouldDeleteState() {
        redisAuthTransactionService.delete("STATE123");

        verify(redisTemplate)
                .delete("auth:state:STATE123");
    }
}
