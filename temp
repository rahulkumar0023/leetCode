## 4. Add JUnit for `AppConfigService`

Location:

```text
src/test/java/com/bnpp/pf/partner/repository/service/AppConfigServiceTest.java
```

```java
@ExtendWith(MockitoExtension.class)
class AppConfigServiceTest {

    @Mock
    private AppConfigRepository appConfigRepository;

    @InjectMocks
    private AppConfigService appConfigService;

    @Test
    void getApp_shouldReturnAppConfig_whenAppExists() {
        AppConfigEntity entity = new AppConfigEntity();
        entity.setAppId("B2BOOST_BE");
        entity.setEnabled(true);
        entity.setClientId("client-id");
        entity.setClientSecret("secret");
        entity.setIssuerUri("issuer");
        entity.setRedirectUri("http://localhost/callback");
        entity.setScopes("openid,profile,email");
        entity.setPostLoginRedirectUrl("http://localhost/post-login");
        entity.setCookieName("ARTHUR_SESSION");
        entity.setSessionTtlSeconds(3600);

        when(appConfigRepository.findByAppId("B2BOOST_BE"))
                .thenReturn(Optional.of(entity));

        AppConfigResponse response = appConfigService.getApp("B2BOOST_BE");

        assertThat(response.getAppId()).isEqualTo("B2BOOST_BE");
        assertThat(response.isEnabled()).isTrue();
        assertThat(response.getClientId()).isEqualTo("client-id");
        assertThat(response.getScopes()).containsExactly("openid", "profile", "email");
        assertThat(response.getSessionTtlSeconds()).isEqualTo(3600);
    }

    @Test
    void getApp_shouldThrowAppNotFoundException_whenAppDoesNotExist() {
        when(appConfigRepository.findByAppId("UNKNOWN"))
                .thenReturn(Optional.empty());

        assertThatThrownBy(() -> appConfigService.getApp("UNKNOWN"))
                .isInstanceOf(AppNotFoundException.class)
                .hasMessage("App not found: UNKNOWN");
    }

    @Test
    void getApp_shouldThrowIllegalArgumentException_whenAppIdIsBlank() {
        assertThatThrownBy(() -> appConfigService.getApp(" "))
                .isInstanceOf(IllegalArgumentException.class)
                .hasMessage("appId must not be blank");

        verifyNoInteractions(appConfigRepository);
    }

    @Test
    void getApp_shouldReturnEmptyScopes_whenScopesIsNull() {
        AppConfigEntity entity = new AppConfigEntity();
        entity.setAppId("B2BOOST_BE");
        entity.setScopes(null);

        when(appConfigRepository.findByAppId("B2BOOST_BE"))
                .thenReturn(Optional.of(entity));

        AppConfigResponse response = appConfigService.getApp("B2BOOST_BE");

        assertThat(response.getScopes()).isEmpty();
    }

    @Test
    void getApp_shouldTrimAndRemoveBlankScopes() {
        AppConfigEntity entity = new AppConfigEntity();
        entity.setAppId("B2BOOST_BE");
        entity.setScopes("openid, profile, , email ");

        when(appConfigRepository.findByAppId("B2BOOST_BE"))
                .thenReturn(Optional.of(entity));

        AppConfigResponse response = appConfigService.getApp("B2BOOST_BE");

        assertThat(response.getScopes()).containsExactly("openid", "profile", "email");
    }
}
