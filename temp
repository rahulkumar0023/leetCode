## 4. Add `UserServiceTest`

```java
@ExtendWith(MockitoExtension.class)
class UserServiceTest {

    @Mock
    private UserRepository userRepository;

    @Mock
    private SalesPointRepository salesPointRepository;

    @Mock
    private PersonSalesPointRelationshipRepository relationshipRepository;

    @InjectMocks
    private UserService userService;

    @Test
    void getUserById_shouldReturnUserWithSalesPoints_whenUserExists() {
        UserEntity user = new UserEntity();
        user.setUserId("testuser");
        user.setUsername("testuser");
        user.setFirstName("Test");
        user.setLastName("User");
        user.setEmail("test@test.com");
        user.setPhoneNumber("+32123456789");

        PersonSalesPointRelationshipEntity rel = new PersonSalesPointRelationshipEntity();
        rel.setPersonUserId("testuser");
        rel.setSalesPointId("SP001");
        rel.setOrgUnitId("ORG001");

        SalesPointEntity salesPoint = new SalesPointEntity();
        salesPoint.setSalesPointId("SP001");
        salesPoint.setLabel("Sales Point 1");

        when(userRepository.findByUserId("testuser")).thenReturn(Optional.of(user));
        when(relationshipRepository.findByPersonUserId("testuser")).thenReturn(List.of(rel));
        when(salesPointRepository.findBySalesPointId("SP001")).thenReturn(Optional.of(salesPoint));

        UserResponse response = userService.getUserById("testuser");

        assertThat(response.getUserId()).isEqualTo("testuser");
        assertThat(response.getUsername()).isEqualTo("testuser");
        assertThat(response.getUserInfo().getFirstName()).isEqualTo("Test");
        assertThat(response.getUserInfo().getEmails()).containsExactly("test@test.com");
        assertThat(response.getSalesPoints()).hasSize(1);
        assertThat(response.getSalesPoints().get(0).getId()).isEqualTo("SP001");
        assertThat(response.getSalesPoints().get(0).getLabel()).isEqualTo("Sales Point 1");
        assertThat(response.getSalesPoints().get(0).getOrgUnitId()).isEqualTo("ORG001");
        assertThat(response.getRoles()).containsExactly("SELLER");
    }

    @Test
    void getUserById_shouldThrowUserNotFoundException_whenUserDoesNotExist() {
        when(userRepository.findByUserId("missing")).thenReturn(Optional.empty());

        assertThatThrownBy(() -> userService.getUserById("missing"))
                .isInstanceOf(UserNotFoundException.class)
                .hasMessage("User not found: missing");
    }

    @Test
    void getUserById_shouldThrowIllegalArgumentException_whenUserIdIsBlank() {
        assertThatThrownBy(() -> userService.getUserById(" "))
                .isInstanceOf(IllegalArgumentException.class)
                .hasMessage("userId must not be blank");

        verifyNoInteractions(userRepository);
    }

    @Test
    void getUserById_shouldReturnEmptySalesPoints_whenUserHasNoRelationships() {
        UserEntity user = new UserEntity();
        user.setUserId("testuser");
        user.setUsername("testuser");

        when(userRepository.findByUserId("testuser")).thenReturn(Optional.of(user));
        when(relationshipRepository.findByPersonUserId("testuser")).thenReturn(List.of());

        UserResponse response = userService.getUserById("testuser");

        assertThat(response.getSalesPoints()).isEmpty();
    }

    @Test
    void getUserById_shouldThrowSalesPointNotFoundException_whenRelationshipSalesPointIsMissing() {
        UserEntity user = new UserEntity();
        user.setUserId("testuser");
        user.setUsername("testuser");

        PersonSalesPointRelationshipEntity rel = new PersonSalesPointRelationshipEntity();
        rel.setPersonUserId("testuser");
        rel.setSalesPointId("SP999");
        rel.setOrgUnitId("ORG999");

        when(userRepository.findByUserId("testuser")).thenReturn(Optional.of(user));
        when(relationshipRepository.findByPersonUserId("testuser")).thenReturn(List.of(rel));
        when(salesPointRepository.findBySalesPointId("SP999")).thenReturn(Optional.empty());

        assertThatThrownBy(() -> userService.getUserById("testuser"))
                .isInstanceOf(SalesPointNotFoundException.class)
                .hasMessage("Sales point not found: SP999");
    }
}
